PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Midtrans Payment Gateway
# Get these from https://dashboard.midtrans.com (Settings > Access Keys)
PUBLIC_MIDTRANS_CLIENT_KEY=your-midtrans-client-key
PUBLIC_MIDTRANS_ENV=sandbox
# Set MIDTRANS_SERVER_KEY as a Supabase Edge Function secret (not exposed to client)
# supabase secrets set MIDTRANS_SERVER_KEY=your-midtrans-server-key
# supabase secrets set MIDTRANS_ENV=sandbox
