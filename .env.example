# Google Analytics 4 — Measurement ID from analytics.google.com
PUBLIC_GA_ID=G-4X9TBCHVEV

PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Midtrans — use sandbox while testing (keys from dashboard.sandbox.midtrans.com)
PUBLIC_MIDTRANS_CLIENT_KEY=your-midtrans-client-key
PUBLIC_MIDTRANS_ENV=sandbox

# Server-side only (Vercel env vars; redeploy after changes):
# MIDTRANS_SERVER_KEY=your-midtrans-server-key

# Midtrans Dashboard → Settings → Configuration (use https://www.paperainstudio.com):
# Payment Notification URL: https://www.paperainstudio.com/api/midtrans-notification
# Finish Redirect URL:        https://www.paperainstudio.com/payment
# Unfinish Redirect URL:      https://www.paperainstudio.com/payment
# Error Redirect URL:         https://www.paperainstudio.com/payment

# Optional: run supabase/patch-005-payment-ready.sql in Supabase SQL Editor
# Optional: run supabase/patch-006-receipt-email.sql for receipt_sent_at column

# Order confirmation emails (Resend — https://resend.com)
#
# REQUIRED in Vercel (Settings → Environment Variables → Production + Preview):
#   RESEND_API_KEY=re_xxxxxxxx          ← exact name; not "resend-vercel" or similar
#   SITE_URL=https://www.paperainstudio.com
#   FROM_EMAIL=orders@paperainstudio.com
#
# Optional:
#   FROM_NAME=paperain studio
#   REPLY_TO_EMAIL=paperainstudio@gmail.com
#
# Resend setup (before production):
#   1. Resend Dashboard → Domains → Add paperainstudio.com
#   2. Add DNS records (TXT, MX, DKIM) at your domain registrar
#   3. Wait until domain shows "Verified"
#   4. FROM_EMAIL must use that domain (e.g. orders@paperainstudio.com)
#
# Supabase setup:
#   Run supabase/patch-006-receipt-email.sql (adds receipt_sent_at column)
#
# After adding/changing env vars in Vercel → Redeploy the project.
