PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Midtrans — use sandbox while testing (matches keys from dashboard.sandbox.midtrans.com)
# Set to "production" only with production keys from dashboard.midtrans.com
PUBLIC_MIDTRANS_CLIENT_KEY=your-midtrans-client-key
PUBLIC_MIDTRANS_ENV=sandbox

# Server-side only (Vercel → Settings → Environment Variables; redeploy after changes):
# MIDTRANS_SERVER_KEY=your-midtrans-server-key
# SUPABASE_SERVICE_KEY=your-service-role-key

# Optional: run supabase/patch-005-payment-ready.sql in Supabase SQL Editor
