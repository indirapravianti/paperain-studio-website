PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Midtrans Payment Gateway (Sandbox)
# Get keys from https://dashboard.sandbox.midtrans.com (Settings > Access Keys)
PUBLIC_MIDTRANS_CLIENT_KEY=your-midtrans-client-key
PUBLIC_MIDTRANS_ENV=sandbox

# Server-side only (Vercel env vars — never expose to client):
# MIDTRANS_SERVER_KEY=your-midtrans-server-key
# SUPABASE_SERVICE_KEY=your-service-role-key (same as service role in Supabase dashboard)
