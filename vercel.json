{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "astro",
  "rewrites": [
    { "source": "/id", "destination": "/" },
    { "source": "/id/:path*", "destination": "/:path*" }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30,
      "includeFiles": "src/data/products.json"
    }
  }
}
