---
import '../styles/global.css';
import AnnouncementBar from '../components/AnnouncementBar.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import InstagramTicker from '../components/InstagramTicker.astro';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';

interface Props {
  title?: string;
}

const { title = 'paperain studio' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="paperain studio - cute stickers, keychains, griptoks, and more" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Zalando+Sans+Expanded:ital,wght@0,200..900;1,200..900&family=Zalando+Sans+SemiExpanded:ital,wght@0,200..900;1,200..900&display=swap" rel="stylesheet" />
    <meta name="supabase-url" content={import.meta.env.PUBLIC_SUPABASE_URL || ''} />
    <meta name="supabase-key" content={import.meta.env.PUBLIC_SUPABASE_ANON_KEY || ''} />
    <meta name="midtrans-client-key" content={import.meta.env.PUBLIC_MIDTRANS_CLIENT_KEY || ''} />
    <meta name="site-url" content={import.meta.env.PUBLIC_SITE_URL || 'https://www.paperainstudio.com'} />
    <link rel="alternate" hreflang="en" href={`${import.meta.env.PUBLIC_SITE_URL || 'https://www.paperainstudio.com'}/`} />
    <link rel="alternate" hreflang="id" href={`${import.meta.env.PUBLIC_SITE_URL || 'https://www.paperainstudio.com'}/id/`} />
    <title>{title} | paperain studio</title>
    <GoogleAnalytics />
    {import.meta.env.PUBLIC_MIDTRANS_CLIENT_KEY && (
      <script
        type="text/javascript"
        src={import.meta.env.PUBLIC_MIDTRANS_ENV === 'production'
          ? 'https://app.midtrans.com/snap/snap.js'
          : 'https://app.sandbox.midtrans.com/snap/snap.js'}
        data-client-key={import.meta.env.PUBLIC_MIDTRANS_CLIENT_KEY}
      />
    )}
  </head>
  <body class="min-h-screen flex flex-col">
    <AnnouncementBar />
    <Navbar />
    <main class="flex-1">
      <slot />
    </main>
    <InstagramTicker />
    <Footer />

    <div id="cart-drawer-overlay" class="fixed inset-0 bg-black/40 z-40 hidden" onclick="toggleCart()"></div>
    <div id="cart-drawer" class="fixed top-0 right-0 h-full w-full max-w-md bg-white z-50 shadow-2xl translate-x-full transition-transform duration-300 flex flex-col">
      <div class="flex items-center justify-between p-6 border-b border-gray-100">
        <h2 class="text-lg font-semibold">Your Cart</h2>
        <button onclick="toggleCart()" class="text-gray-400 hover:text-gray-600 text-2xl">&times;</button>
      </div>
      <div id="cart-items" class="flex-1 overflow-y-auto p-6">
        <p class="text-gray-400 text-center py-12">Your cart is empty</p>
      </div>
      <div id="cart-footer" class="border-t border-gray-100 p-6 hidden">
        <div id="cart-discount" class="text-sm text-green-600 mb-2 hidden"></div>
        <div class="flex justify-between items-center mb-4">
          <span class="font-medium">Total</span>
          <span id="cart-total" class="text-lg font-semibold">$0.00</span>
        </div>
        <a href="/checkout" id="cart-checkout-link" class="block w-full bg-burgundy text-white text-center py-3 rounded-lg hover:bg-burgundy/80 transition-colors market-aware-link" data-href="/checkout">Checkout</a>
      </div>
    </div>

    <script is:inline>
      var IDR_PLACEHOLDER = 13000;
      var SHIPPING_USD = 3;
      var SHIPPING_IDR = 48000;
      var DISCOUNT_THRESHOLD_USD = 50;
      var DISCOUNT_THRESHOLD_IDR = 80000;
      var DISCOUNT_RATE = 0.2;
      var USD_TO_IDR = 16000;
      var IDR_CATEGORY_PRICES = {
        'sticker sheet': 13000,
        keychain: 20000,
        griptok: 27000,
        artprint: 10000,
        'greeting card': 14000,
        postcard: 10000,
        phonestrap: 22000
      };

      function getMarket() {
        return 'id';
      }

      function getCurrency() {
        return 'IDR';
      }

      function getIdrPriceForCategory(category) {
        if (category && IDR_CATEGORY_PRICES[category]) return IDR_CATEGORY_PRICES[category];
        return IDR_PLACEHOLDER;
      }

      function stripMarketPrefix(path) {
        if (path === '/id') return '/';
        if (path.startsWith('/id/')) return path.slice(3) || '/';
        return path;
      }

      function marketPath(path) {
        var base = stripMarketPrefix(path);
        if (getMarket() === 'id') return base === '/' ? '/id' : '/id' + base;
        return base;
      }

      function formatPrice(amount, currency) {
        currency = currency || getCurrency();
        if (currency === 'IDR') return 'Rp' + Math.round(Number(amount)).toLocaleString('id-ID');
        return '$' + Number(amount).toFixed(2);
      }

      function getDisplayPrice(usd, idr, category) {
        if (getCurrency() === 'IDR') {
          if (idr != null) return idr;
          if (category) return getIdrPriceForCategory(category);
          return IDR_PLACEHOLDER;
        }
        return Number(usd);
      }

      function getShippingFee(currency) {
        return (currency || getCurrency()) === 'IDR' ? SHIPPING_IDR : SHIPPING_USD;
      }

      function getVolumeDiscount(subtotal, currency) {
        currency = currency || getCurrency();
        var threshold = currency === 'IDR' ? DISCOUNT_THRESHOLD_IDR : DISCOUNT_THRESHOLD_USD;
        return subtotal >= threshold ? subtotal * DISCOUNT_RATE : 0;
      }

      function applyMarketLinks() {
        document.querySelectorAll('.market-aware-link').forEach(function(el) {
          var href = el.getAttribute('data-href') || el.getAttribute('href');
          if (href) el.setAttribute('href', marketPath(href));
        });
      }

      function applyMarketPrices() {
        document.querySelectorAll('.market-price').forEach(function(el) {
          var usd = parseFloat(el.getAttribute('data-usd') || '0');
          var idr = parseFloat(el.getAttribute('data-idr') || String(IDR_PLACEHOLDER));
          el.textContent = formatPrice(getDisplayPrice(usd, idr));
        });
      }

      function getApiAuthHeader() {
        var key = document.querySelector('meta[name="supabase-key"]')?.content;
        var token = localStorage.getItem('sb-access-token');
        if (token && !isTokenExpired(token)) {
          return 'Bearer ' + token;
        }
        return 'Bearer ' + (key || '');
      }

      function getCart() {
        try { return JSON.parse(localStorage.getItem('paperain-cart') || '[]'); }
        catch { return []; }
      }

      function saveCart(cart) {
        localStorage.setItem('paperain-cart', JSON.stringify(cart));
        updateCartUI();
        updateCartCount();
      }

      function addToCart(product) {
        const cart = getCart();
        const currency = getCurrency();
        const price = getDisplayPrice(product.priceUsd || product.price, product.priceIdr, product.category);
        const existing = cart.find(item => item.id === product.id && item.currency === currency);
        if (existing) {
          existing.qty += product.qty || 1;
        } else {
          cart.push({
            id: product.id,
            title: product.title,
            price: price,
            priceUsd: product.priceUsd || product.price,
            priceIdr: product.priceIdr || getIdrPriceForCategory(product.category),
            image: product.image,
            category: product.category,
            currency: currency,
            qty: product.qty || 1,
          });
        }
        saveCart(cart);
        toggleCart(true);
      }

      function removeFromCart(id) {
        const cart = getCart().filter(item => item.id !== id);
        saveCart(cart);
      }

      function updateQty(id, delta) {
        const cart = getCart();
        const item = cart.find(i => i.id === id);
        if (!item) return;
        item.qty += delta;
        if (item.qty <= 0) {
          saveCart(cart.filter(i => i.id !== id));
        } else {
          saveCart(cart);
        }
      }

      function toggleCart(forceOpen) {
        const drawer = document.getElementById('cart-drawer');
        const overlay = document.getElementById('cart-drawer-overlay');
        const isOpen = !drawer.classList.contains('translate-x-full');
        if (forceOpen === true || !isOpen) {
          drawer.classList.remove('translate-x-full');
          overlay.classList.remove('hidden');
          document.body.style.overflow = 'hidden';
          updateCartUI();
        } else {
          drawer.classList.add('translate-x-full');
          overlay.classList.add('hidden');
          document.body.style.overflow = '';
        }
      }

      function updateCartCount() {
        const cart = getCart();
        const count = cart.reduce((sum, item) => sum + item.qty, 0);
        document.querySelectorAll('.cart-count').forEach(el => {
          el.textContent = count;
          el.style.display = count > 0 ? 'flex' : 'none';
        });
      }

      function updateCartUI() {
        const cart = getCart().filter(function(item) { return item.currency === getCurrency(); });
        const container = document.getElementById('cart-items');
        const footer = document.getElementById('cart-footer');
        const totalEl = document.getElementById('cart-total');
        const discountEl = document.getElementById('cart-discount');
        const currency = getCurrency();

        if (cart.length === 0) {
          var shopPath = typeof marketPath === 'function' ? marketPath('/products') : '/products';
          container.innerHTML =
            '<div class="text-center py-12">' +
              '<p class="text-gray-400 mb-6">your cart is empty</p>' +
              '<a href="' + shopPath + '" class="inline-block bg-burgundy text-white text-sm rounded-full px-6 py-2.5 hover:bg-burgundy/80 transition-colors" onclick="toggleCart()">shop now</a>' +
            '</div>';
          footer.classList.add('hidden');
          return;
        }

        footer.classList.remove('hidden');

        let subtotal = cart.reduce((sum, item) => sum + item.price * item.qty, 0);
        let discount = getVolumeDiscount(subtotal, currency);
        const total = subtotal - discount;

        if (discount > 0) {
          discountEl.classList.remove('hidden');
          discountEl.className = 'text-sm text-green-600 mb-2';
          discountEl.textContent = '20% discount applied! You save ' + formatPrice(discount, currency);
        } else {
          var threshold = currency === 'IDR' ? DISCOUNT_THRESHOLD_IDR : DISCOUNT_THRESHOLD_USD;
          var remaining = threshold - subtotal;
          if (remaining > 0 && remaining <= (currency === 'IDR' ? 200000 : 20)) {
            discountEl.classList.remove('hidden');
            discountEl.className = 'text-sm text-amber-600 mb-2';
            discountEl.textContent = 'Add ' + formatPrice(remaining, currency) + ' more to get 20% off!';
          } else {
            discountEl.classList.add('hidden');
          }
        }

        totalEl.textContent = formatPrice(total, currency);
        container.innerHTML = cart.map(item => {
          return `
          <div class="flex gap-4 py-4 border-b border-gray-50">
            <img src="${item.image}" alt="${item.title}" class="w-16 h-16 object-cover rounded-lg" />
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium truncate">${item.title}</p>
              <p class="text-sm text-gray-500">${formatPrice(item.price, currency)}</p>
              <div class="flex items-center gap-2 mt-1">
                <button onclick="updateQty('${item.id}', -1)" class="w-6 h-6 rounded border border-gray-200 text-xs hover:bg-gray-50">−</button>
                <span class="text-sm">${item.qty}</span>
                <button onclick="updateQty('${item.id}', 1)" class="w-6 h-6 rounded border border-gray-200 text-xs hover:bg-gray-50">+</button>
              </div>
            </div>
            <button onclick="removeFromCart('${item.id}')" class="text-gray-300 hover:text-red-400 text-lg self-start">&times;</button>
          </div>`;
        }).join('');
      }

      // Auth: token refresh + auto-logout on expiry
      function parseJwt(token) {
        try {
          var base64 = token.split('.')[1].replace(/-/g, '+').replace(/_/g, '/');
          return JSON.parse(atob(base64));
        } catch { return null; }
      }

      function isTokenExpired(token) {
        if (!token) return true;
        var payload = parseJwt(token);
        if (!payload || !payload.exp) return true;
        return Date.now() >= payload.exp * 1000;
      }

      async function tryRefreshToken() {
        var SUPABASE_URL = document.querySelector('meta[name="supabase-url"]')?.content;
        var SUPABASE_KEY = document.querySelector('meta[name="supabase-key"]')?.content;
        var refreshToken = localStorage.getItem('sb-refresh-token');
        if (!SUPABASE_URL || !SUPABASE_KEY || !refreshToken) return false;
        try {
          var res = await fetch(SUPABASE_URL + '/auth/v1/token?grant_type=refresh_token', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_KEY },
            body: JSON.stringify({ refresh_token: refreshToken }),
          });
          if (!res.ok) return false;
          var data = await res.json();
          localStorage.setItem('sb-access-token', data.access_token);
          localStorage.setItem('sb-refresh-token', data.refresh_token);
          localStorage.setItem('sb-user', JSON.stringify(data.user));
          return true;
        } catch { return false; }
      }

      function doLogout() {
        localStorage.removeItem('sb-access-token');
        localStorage.removeItem('sb-refresh-token');
        localStorage.removeItem('sb-user');
      }

      function updateNavAuth() {
        var signinEl = document.getElementById('nav-signin');
        var accountEl = document.getElementById('nav-account');
        var mobileGuest = document.getElementById('mobile-auth-guest');
        var mobileUser = document.getElementById('mobile-auth-user');
        var nameEl = document.getElementById('nav-account-name');
        var mobileNameEl = document.getElementById('mobile-account-name');
        var user = null;

        try { user = JSON.parse(localStorage.getItem('sb-user')); } catch {}

        if (user && user.email) {
          var displayName = (user.user_metadata && user.user_metadata.full_name
            ? user.user_metadata.full_name
            : user.email.split('@')[0]).split(' ')[0].toLowerCase();
          if (signinEl) signinEl.classList.add('hidden');
          if (accountEl) accountEl.classList.remove('hidden');
          if (mobileGuest) mobileGuest.classList.add('hidden');
          if (mobileUser) mobileUser.classList.remove('hidden');
          if (nameEl) nameEl.textContent = displayName;
          if (mobileNameEl) mobileNameEl.textContent = displayName;
        } else {
          if (signinEl) signinEl.classList.remove('hidden');
          if (accountEl) accountEl.classList.add('hidden');
          if (mobileGuest) mobileGuest.classList.remove('hidden');
          if (mobileUser) mobileUser.classList.add('hidden');
        }
      }

      async function checkAuth() {
        var token = localStorage.getItem('sb-access-token');
        if (!token) {
          updateNavAuth();
          return;
        }
        if (isTokenExpired(token)) {
          var refreshed = await tryRefreshToken();
          if (!refreshed) {
            doLogout();
            var isProtected = window.location.pathname.startsWith('/account') ||
                              window.location.pathname.startsWith('/admin');
            if (isProtected) {
              window.location.href = '/auth/signin';
              return;
            }
          }
        }
        updateNavAuth();
      }

      document.addEventListener('DOMContentLoaded', function() {
        applyMarketLinks();
        applyMarketPrices();
        checkAuth();
        updateCartCount();
      });
    </script>
  </body>
</html>
