            <div class="w-8 h-8 bg-pink/50 rounded-full flex items-center justify-center text-xs font-medium text-dark-green">N</div>
            <div>
              <p class="text-xs font-medium">Nadia P.</p>
              <p class="text-xs text-gray-400">Shopee</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    .reviews-track {
      animation: scroll-reviews 40s linear infinite;
    }
    .reviews-track:hover {
      animation-play-state: paused;
    }
    @keyframes scroll-reviews {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
  </style>

  <script is:inline>
    // Duplicate review cards for seamless loop
    (function() {
      var track = document.getElementById('reviews-track');
      if (!track) return;
      var cards = track.innerHTML;
      track.innerHTML = cards + cards;
    })();
  </script>

  <!-- CTA Banner -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="bg-lime rounded-2xl p-8 sm:p-12 text-center">
      <h2 class="text-xl sm:text-2xl font-semibold text-dark-green mb-2">spend $50 and get 20% off!</h2>
      <p class="text-sm text-dark-green/70 mb-6">stock up on your favorites and save big</p>
      <a href="/products" class="inline-block bg-dark-green text-white text-sm rounded-full px-8 py-3 hover:bg-dark-green/80 transition-colors">
        shop now
      </a>
    </div>
  </section>
</Layout>
