          </svg>
        </div>
      </a>
    </div>
  </section>

  <!-- Customer Love Letters -->
  <section class="bg-pink/20 py-16 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-2xl font-semibold">our love letters</h2>
        <p class="text-sm text-muted mt-2">kind words from our customers</p>
      </div>
    </div>

    <div class="relative">
      <div class="reviews-track flex gap-6 px-4" id="reviews-track">
        <div class="review-card shrink-0 w-[300px] bg-white rounded-2xl p-6 shadow-sm">
          <div class="flex gap-1 mb-3">
            <span class="text-lime text-sm">★★★★★</span>
