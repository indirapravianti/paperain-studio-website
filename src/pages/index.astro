---
import Layout from '../layouts/Layout.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import ProductTicker from '../components/ProductTicker.astro';
import ProductCard from '../components/ProductCard.astro';
import products from '../data/products.json';

const activeProducts = products.filter(p => p.isActive);
const newItems = activeProducts.filter(p => p.isNew).slice(0, 4);
const favorites = activeProducts.filter(p => p.isFavorite).slice(0, 4);

const tickerIds = ['kc-004', 'kc-001', 'st-004', 'gt-001', 'st-014', 'ap-007'];
const tickerItems = tickerIds
  .map(id => activeProducts.find(p => p.id === id))
  .filter(Boolean)
  .map(p => ({ id: p.id, title: p.title, image: p.image, price: p.price }));
---

<Layout title="home">
  <HeroCarousel />

  <!-- Product Ticker -->
  <ProductTicker items={tickerItems} />

  <!-- New Arrivals -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-10">
      <h2 class="text-2xl font-semibold">new arrivals🔮</h2>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 sm:gap-6">
      {newItems.map(product => (
        <ProductCard
          id={product.id}
          title={product.title}
          price={product.price}
          image={product.image}
          isNew={product.isNew}
          category={product.category}
        />
      ))}
    </div>
    <div class="text-center mt-8">
      <a href="/products" class="inline-block text-sm border border-burgundy/20 rounded-full px-6 py-2 text-burgundy hover:border-burgundy hover:bg-burgundy hover:text-white transition-colors">
        view all products
      </a>
    </div>
  </section>

  <!-- Favorite Picks -->
  <section class="bg-buttermilk/30 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-2xl font-semibold">favorite picks🪶</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 sm:gap-6">
        {favorites.map(product => (
          <ProductCard
            id={product.id}
            title={product.title}
            price={product.price}
            image={product.image}
            isNew={product.isNew}
            category={product.category}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Instagram Posts -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-10">
      <h2 class="text-2xl font-semibold">follow us on instagram</h2>
      <a href="https://instagram.com/paperainstudio" target="_blank" rel="noopener" class="text-sm text-muted hover:text-primary transition-colors mt-2 inline-block">@paperainstudio</a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <a href="https://www.instagram.com/p/DUIJZaMkQLb/" target="_blank" rel="noopener"
        class="group relative aspect-square rounded-xl overflow-hidden bg-gray-100">
        <iframe src="https://www.instagram.com/p/DUIJZaMkQLb/embed" class="w-full h-full border-0 pointer-events-none" loading="lazy" title="Instagram post 1"></iframe>
        <div class="absolute inset-0 bg-burgundy/0 group-hover:bg-burgundy/20 transition-colors flex items-center justify-center">
          <svg class="w-8 h-8 text-white opacity-0 group-hover:opacity-100 transition-opacity drop-shadow-lg" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
        </div>
      </a>
      <a href="https://www.instagram.com/p/DX6azaHH5Y9/" target="_blank" rel="noopener"
        class="group relative aspect-square rounded-xl overflow-hidden bg-gray-100">
        <iframe src="https://www.instagram.com/p/DX6azaHH5Y9/embed" class="w-full h-full border-0 pointer-events-none" loading="lazy" title="Instagram post 2"></iframe>
        <div class="absolute inset-0 bg-burgundy/0 group-hover:bg-burgundy/20 transition-colors flex items-center justify-center">
          <svg class="w-8 h-8 text-white opacity-0 group-hover:opacity-100 transition-opacity drop-shadow-lg" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
        </div>
      </a>
      <a href="https://www.instagram.com/p/DYR6FUKIBhP/" target="_blank" rel="noopener"
        class="group relative aspect-square rounded-xl overflow-hidden bg-gray-100">
        <iframe src="https://www.instagram.com/p/DYR6FUKIBhP/embed" class="w-full h-full border-0 pointer-events-none" loading="lazy" title="Instagram post 3"></iframe>
        <div class="absolute inset-0 bg-burgundy/0 group-hover:bg-burgundy/20 transition-colors flex items-center justify-center">
          <svg class="w-8 h-8 text-white opacity-0 group-hover:opacity-100 transition-opacity drop-shadow-lg" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
        </div>
      </a>
    </div>
  </section>

  <!-- Customer Love Letters -->
  <section class="bg-pastel-blue/20 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-2xl font-semibold">our love letters⋆｡°✩</h2>
        <p class="text-sm text-muted mt-2">kind words from our friends</p>
      </div>

      <div class="relative">
        <!-- Arrow Left -->
        <button id="reviews-prev" class="absolute -left-2 sm:left-0 top-1/2 -translate-y-1/2 z-10 w-10 h-10 bg-white rounded-full shadow-md flex items-center justify-center text-burgundy hover:bg-burgundy hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </button>

        <!-- Cards Container -->
        <div class="overflow-hidden mx-8 sm:mx-12" id="reviews-viewport">
          <div class="flex gap-6 transition-transform duration-300 ease-in-out" id="reviews-track">
            <div class="review-card shrink-0 w-[280px] sm:w-[320px] bg-white rounded-2xl p-6 shadow-sm">
              <div class="flex gap-1 mb-3"><span class="text-accent text-sm">★★★★★</span></div>
              <p class="text-sm text-gray-600 leading-relaxed mb-4">"desain stikernya bagus banget, print-nya juga bagusss, top banget pokoknya 🥹 lucu, gemes, cakepp. packing-nya juga aman banget dan rapih 🫂🫂🫂"</p>
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-buttermilk/30 rounded-full flex items-center justify-center text-xs font-medium text-burgundy">F</div>
                <div><p class="text-xs font-medium">Fia</p><p class="text-xs text-gray-400">Shopee</p></div>
              </div>
            </div>

            <div class="review-card shrink-0 w-[280px] sm:w-[320px] bg-white rounded-2xl p-6 shadow-sm">
              <div class="flex gap-1 mb-3"><span class="text-accent text-sm">★★★★★</span></div>
              <p class="text-sm text-gray-600 leading-relaxed mb-4">"it's perfect as it is. 🔆 thank you for creating such a nice piece!!!"</p>
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-pastel-blue/50 rounded-full flex items-center justify-center text-xs font-medium text-burgundy">D</div>
                <div><p class="text-xs font-medium">Dian</p><p class="text-xs text-gray-400">Shopee</p></div>
              </div>
            </div>

            <div class="review-card shrink-0 w-[280px] sm:w-[320px] bg-white rounded-2xl p-6 shadow-sm">
              <div class="flex gap-1 mb-3"><span class="text-accent text-sm">★★★★★</span></div>
              <p class="text-sm text-gray-600 leading-relaxed mb-4">"barang sampai dengan aman, kualitasnya oke sekaliii, dipasang di tumblr juga bagus! semoga awet"</p>
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-buttermilk/30 rounded-full flex items-center justify-center text-xs font-medium text-burgundy">K</div>
                <div><p class="text-xs font-medium">Khanisa</p><p class="text-xs text-gray-400">Shopee</p></div>
              </div>
            </div>

            <div class="review-card shrink-0 w-[280px] sm:w-[320px] bg-white rounded-2xl p-6 shadow-sm">
              <div class="flex gap-1 mb-3"><span class="text-accent text-sm">★★★★★</span></div>
              <p class="text-sm text-gray-600 leading-relaxed mb-4">"Mantab banget sesuai foto komplit buat jurnaling, keren deh, sukakpuol"</p>
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-pastel-blue/50 rounded-full flex items-center justify-center text-xs font-medium text-burgundy">D</div>
                <div><p class="text-xs font-medium">Debora</p><p class="text-xs text-gray-400">Shopee</p></div>
              </div>
            </div>

            <div class="review-card shrink-0 w-[280px] sm:w-[320px] bg-white rounded-2xl p-6 shadow-sm">
              <div class="flex gap-1 mb-3"><span class="text-accent text-sm">★★★★★</span></div>
              <p class="text-sm text-gray-600 leading-relaxed mb-4">"Puas bangettt..mana cantik bgt tulisannya. Di kasih bonus stiker byk bgt.. Makasii seller"</p>
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-buttermilk/30 rounded-full flex items-center justify-center text-xs font-medium text-burgundy">V</div>
                <div><p class="text-xs font-medium">Vidya</p><p class="text-xs text-gray-400">Shopee</p></div>
              </div>
            </div>

            <div class="review-card shrink-0 w-[280px] sm:w-[320px] bg-white rounded-2xl p-6 shadow-sm">
              <div class="flex gap-1 mb-3"><span class="text-accent text-sm">★★★★★</span></div>
              <p class="text-sm text-gray-600 leading-relaxed mb-4">"LUCUUUU BANGET, akriliknya tebel, and the print is good quality! The packaging is good and adorable, the duck is sooo cute, suka banget!"</p>
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-pastel-blue/50 rounded-full flex items-center justify-center text-xs font-medium text-burgundy">T</div>
                <div><p class="text-xs font-medium">Trex</p><p class="text-xs text-gray-400">Shopee</p></div>
              </div>
            </div>

            <div class="review-card shrink-0 w-[280px] sm:w-[320px] bg-white rounded-2xl p-6 shadow-sm">
              <div class="flex gap-1 mb-3"><span class="text-accent text-sm">★★★★★</span></div>
              <p class="text-sm text-gray-600 leading-relaxed mb-4">"cuma beli satuu tp dpt free stikernya banyak bgtt😭 trs packingnya juga niatttt yaampuunnn😭💖💖✨ kaa maaf yaa cuma beli satu doangg, lain kali aku beli banyakk deh kl tau kaka nya sebaik inii!!!😭✨✨✨"</p>
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-buttermilk/30 rounded-full flex items-center justify-center text-xs font-medium text-burgundy">T</div>
                <div><p class="text-xs font-medium">Tiara</p><p class="text-xs text-gray-400">Shopee</p></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Arrow Right -->
        <button id="reviews-next" class="absolute -right-2 sm:right-0 top-1/2 -translate-y-1/2 z-10 w-10 h-10 bg-white rounded-full shadow-md flex items-center justify-center text-burgundy hover:bg-burgundy hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>
    </div>
  </section>

  <script is:inline>
    (function() {
      var track = document.getElementById('reviews-track');
      var prev = document.getElementById('reviews-prev');
      var next = document.getElementById('reviews-next');
      if (!track || !prev || !next) return;

      var pos = 0;
      var cards = track.querySelectorAll('.review-card');
      if (!cards.length) return;

      function getCardWidth() {
        return cards[0].offsetWidth + 24;
      }

      function getMaxPos() {
        var viewport = document.getElementById('reviews-viewport');
        return Math.max(0, track.scrollWidth - viewport.offsetWidth);
      }

      function update() {
        track.style.transform = 'translateX(-' + pos + 'px)';
      }

      prev.addEventListener('click', function() {
        pos = Math.max(0, pos - getCardWidth());
        update();
      });

      next.addEventListener('click', function() {
        pos = Math.min(getMaxPos(), pos + getCardWidth());
        update();
      });
    })();
  </script>

  <!-- CTA Banner -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="bg-pastel-blue rounded-2xl p-8 sm:p-12 text-center">
      <h2 class="text-xl sm:text-2xl font-semibold text-burgundy mb-2">special promo: 20% off orders above Rp80.000!</h2>
      <p class="text-sm text-burgundy/70 mb-6">stock up on your favorites and save big</p>
      <a href="/products" class="inline-block bg-burgundy text-white text-sm rounded-full px-8 py-3 hover:bg-burgundy/80 transition-colors">
        shop now
      </a>
    </div>
  </section>
</Layout>
