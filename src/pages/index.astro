---
import Layout from '../layouts/Layout.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import ProductCard from '../components/ProductCard.astro';
import products from '../data/products.json';

const newItems = products.filter(p => p.isNew).slice(0, 4);
const favorites = products.filter(p => p.isFavorite).slice(0, 4);
---

<Layout title="Home">
  <HeroCarousel />

  <!-- New Arrivals -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-10">
      <h2 class="text-2xl font-semibold">New Arrivals</h2>
      <p class="text-sm text-gray-400 mt-2">Fresh designs, just added</p>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 sm:gap-6">
      {newItems.map(product => (
        <ProductCard
          id={product.id}
          title={product.title}
          price={product.price}
          image={product.image}
          isNew={product.isNew}
        />
      ))}
    </div>
    <div class="text-center mt-8">
      <a href="/products" class="inline-block text-sm border border-gray-200 rounded-full px-6 py-2 text-gray-600 hover:border-gray-400 hover:text-primary transition-colors">
        View All Products →
      </a>
    </div>
  </section>

  <!-- Favorite Picks -->
  <section class="bg-gray-50/50 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-2xl font-semibold">♡ Favorite Picks ♡</h2>
        <p class="text-sm text-gray-400 mt-2">Most loved by our customers</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 sm:gap-6">
        {favorites.map(product => (
          <ProductCard
            id={product.id}
            title={product.title}
            price={product.price}
            image={product.image}
            isNew={product.isNew}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="bg-accent-light rounded-2xl p-8 sm:p-12 text-center">
      <h2 class="text-xl sm:text-2xl font-semibold mb-2">Spend $50 and get 20% off!</h2>
      <p class="text-sm text-gray-600 mb-6">Stock up on your favorites and save big</p>
      <a href="/products" class="inline-block bg-primary text-white text-sm rounded-full px-8 py-3 hover:bg-gray-800 transition-colors">
        Shop Now
      </a>
    </div>
  </section>
</Layout>
