---
import Layout from '../layouts/Layout.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import ProductTicker from '../components/ProductTicker.astro';
import ProductCard from '../components/ProductCard.astro';
import products from '../data/products.json';

const activeProducts = products.filter(p => p.isActive);
const newItems = activeProducts.filter(p => p.isNew).slice(0, 4);
const favorites = activeProducts.filter(p => p.isFavorite).slice(0, 4);

const tickerIds = ['kc-004', 'kc-001', 'st-004', 'gt-001', 'st-014', 'ap-007'];
const tickerItems = tickerIds
  .map(id => activeProducts.find(p => p.id === id))
  .filter(Boolean)
  .map(p => ({ id: p.id, title: p.title, image: p.image, price: p.price }));
---

<Layout title="home">
  <HeroCarousel />

  <!-- Product Ticker -->
  <ProductTicker items={tickerItems} />

  <!-- New Arrivals -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-10">
      <h2 class="text-2xl font-semibold">new arrivals</h2>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 sm:gap-6">
      {newItems.map(product => (
        <ProductCard
          id={product.id}
          title={product.title}
          price={product.price}
          image={product.image}
          isNew={product.isNew}
          category={product.category}
        />
      ))}
    </div>
    <div class="text-center mt-8">
      <a href="/products" class="inline-block text-sm border border-dark-green/20 rounded-full px-6 py-2 text-dark-green hover:border-dark-green hover:bg-dark-green hover:text-white transition-colors">
        view all products
      </a>
    </div>
  </section>

  <!-- Favorite Picks -->
  <section class="bg-pink/30 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-2xl font-semibold">favorite picks</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 sm:gap-6">
        {favorites.map(product => (
          <ProductCard
            id={product.id}
            title={product.title}
            price={product.price}
            image={product.image}
            isNew={product.isNew}
            category={product.category}
          />
        ))}
