---
import Layout from '../layouts/Layout.astro';
---

<Layout title="payment">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-10">
    <!-- Loading state -->
    <div id="payment-loading" class="text-center py-20">
      <div class="w-10 h-10 border-2 border-primary border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
      <p class="text-gray-400 text-sm">loading your order...</p>
    </div>

    <!-- Error state -->
    <div id="payment-error" class="hidden text-center py-20">
      <div class="w-16 h-16 bg-red-50 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
        </svg>
      </div>
      <h2 class="text-xl font-semibold mb-2">order not found</h2>
      <p class="text-gray-500 text-sm mb-6">we couldn't find that order, or it's no longer available for payment.</p>
      <a href="/" class="inline-block text-sm border border-gray-200 rounded-full px-6 py-2 text-gray-600 hover:border-gray-400 transition-colors">
        back to shop
      </a>
    </div>

    <!-- Payment content -->
    <div id="payment-content" class="hidden">
      <div class="flex items-center gap-2 mb-8">
        <a href="/account" class="text-gray-400 hover:text-primary transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
        </a>
        <h1 class="text-2xl font-semibold">payment</h1>
      </div>

      <div class="grid md:grid-cols-5 gap-8">
        <!-- Payment Methods -->
        <div class="md:col-span-3">
          <!-- Order info bar -->
          <div class="bg-pastel-blue/15 border border-pastel-blue/30 rounded-lg p-4 mb-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-xs text-gray-400">order</p>
                <p id="pay-order-id" class="text-sm font-medium"></p>
              </div>
              <span id="pay-status" class="text-xs px-3 py-1.5 rounded-full font-medium bg-yellow-100 text-yellow-700">pending</span>
            </div>
          </div>

          <!-- Payment method selector -->
          <div class="mb-6">
            <h2 class="font-medium mb-4">select payment method</h2>

            <div class="space-y-3" id="payment-methods">
              <!-- Credit/Debit Card -->
              <label class="payment-method-option flex items-center gap-4 border border-gray-200 rounded-xl p-4 cursor-pointer hover:border-primary/40 transition-colors has-[:checked]:border-primary has-[:checked]:bg-primary/5">
                <input type="radio" name="payment-method" value="credit_card" class="accent-primary w-4 h-4" checked />
                <div class="flex items-center gap-3 flex-1">
                  <div class="w-10 h-10 bg-gray-50 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm font-medium">credit / debit card</p>
                    <p class="text-xs text-gray-400">visa, mastercard, jcb</p>
                  </div>
                </div>
              </label>

              <!-- Bank Transfer -->
              <label class="payment-method-option flex items-center gap-4 border border-gray-200 rounded-xl p-4 cursor-pointer hover:border-primary/40 transition-colors has-[:checked]:border-primary has-[:checked]:bg-primary/5">
                <input type="radio" name="payment-method" value="bank_transfer" class="accent-primary w-4 h-4" />
                <div class="flex items-center gap-3 flex-1">
                  <div class="w-10 h-10 bg-gray-50 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm font-medium">bank transfer</p>
                    <p class="text-xs text-gray-400">bca, bni, bri, mandiri, permata</p>
                  </div>
                </div>
              </label>

              <!-- E-Wallet -->
              <label class="payment-method-option flex items-center gap-4 border border-gray-200 rounded-xl p-4 cursor-pointer hover:border-primary/40 transition-colors has-[:checked]:border-primary has-[:checked]:bg-primary/5">
                <input type="radio" name="payment-method" value="e_wallet" class="accent-primary w-4 h-4" />
                <div class="flex items-center gap-3 flex-1">
                  <div class="w-10 h-10 bg-gray-50 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm font-medium">e-wallet</p>
                    <p class="text-xs text-gray-400">gopay, shopeepay, dana, ovo</p>
                  </div>
                </div>
              </label>

              <!-- QRIS -->
              <label class="payment-method-option flex items-center gap-4 border border-gray-200 rounded-xl p-4 cursor-pointer hover:border-primary/40 transition-colors has-[:checked]:border-primary has-[:checked]:bg-primary/5">
                <input type="radio" name="payment-method" value="qris" class="accent-primary w-4 h-4" />
                <div class="flex items-center gap-3 flex-1">
                  <div class="w-10 h-10 bg-gray-50 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm font-medium">qris</p>
                    <p class="text-xs text-gray-400">scan with any e-wallet or banking app</p>
                  </div>
                </div>
              </label>
            </div>
          </div>

          <!-- Pay button -->
          <div id="pay-error" class="text-sm text-red-500 mb-3 hidden"></div>
          <button id="pay-btn"
            class="w-full bg-primary text-white py-3.5 rounded-lg hover:bg-primary/80 transition-colors text-sm font-medium">
            pay now
          </button>
          <p class="text-xs text-gray-400 text-center mt-3">
            secured by <span class="font-medium text-gray-500">midtrans</span> payment gateway
          </p>

          <!-- Midtrans setup notice -->
          <div id="midtrans-notice" class="mt-6 bg-buttermilk/40 border border-buttermilk rounded-lg p-4 hidden">
            <p class="text-sm text-gray-600">
              <span class="font-medium">payment gateway is being set up.</span>
              we're currently finalizing our payment integration with midtrans. 
              in the meantime, your order has been recorded and we'll reach out to you via email with payment instructions.
            </p>
          </div>
        </div>

        <!-- Order Summary Sidebar -->
        <div class="md:col-span-2">
          <div class="bg-gray-50 rounded-xl p-6 sticky top-24">
            <h2 class="font-medium mb-4">order summary</h2>
            <div id="pay-items" class="space-y-3 mb-4"></div>

            <div class="border-t border-gray-200 pt-4 space-y-2">
              <div class="flex justify-between text-sm">
                <span class="text-gray-500">subtotal</span>
                <span id="pay-subtotal" class="text-gray-600"></span>
              </div>
              <div id="pay-discount-row" class="flex justify-between text-sm text-green-600 hidden">
                <span>discount</span>
                <span id="pay-discount"></span>
              </div>
              <div id="pay-promo-row" class="flex justify-between text-sm text-green-600 hidden">
                <span id="pay-promo-label">promo</span>
                <span id="pay-promo-discount"></span>
              </div>
              <div class="flex justify-between text-sm">
                <span class="text-gray-500">shipping</span>
                <span id="pay-shipping" class="text-gray-600"></span>
              </div>
              <div class="flex justify-between font-medium border-t border-gray-200 pt-2">
                <span>total</span>
                <span id="pay-total"></span>
              </div>
            </div>

            <!-- Shipping info summary -->
            <div class="border-t border-gray-200 pt-4 mt-4">
              <p class="text-xs text-gray-400 mb-2">shipping to</p>
              <p id="pay-ship-name" class="text-sm font-medium"></p>
              <p id="pay-ship-address" class="text-sm text-gray-500 mt-0.5 whitespace-pre-line"></p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Payment success state -->
    <div id="payment-success" class="hidden text-center py-12">
      <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h2 class="text-xl font-semibold mb-2">payment successful!</h2>
      <p class="text-gray-500 text-sm mb-2">thank you! your payment has been received.</p>
      <p id="pay-success-id" class="text-xs text-gray-400 mb-6"></p>
      <div class="flex justify-center gap-3">
        <a href="/account" id="pay-view-orders" class="hidden inline-block text-sm border border-gray-200 rounded-full px-6 py-2 text-gray-600 hover:border-gray-400 transition-colors">
          view my orders
        </a>
        <a href="/" class="inline-block text-sm border border-gray-200 rounded-full px-6 py-2 text-gray-600 hover:border-gray-400 transition-colors">
          continue shopping
        </a>
      </div>
    </div>

    <!-- Payment pending / waiting state -->
    <div id="payment-pending" class="hidden text-center py-12">
      <div class="w-16 h-16 bg-yellow-100 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <h2 class="text-xl font-semibold mb-2">waiting for payment</h2>
      <p class="text-gray-500 text-sm mb-2">please complete your payment using the method you selected.</p>
      <p class="text-gray-400 text-xs mb-6">we'll send a confirmation email once we receive your payment.</p>
      <div class="flex justify-center gap-3">
        <a href="/account" class="inline-block text-sm border border-gray-200 rounded-full px-6 py-2 text-gray-600 hover:border-gray-400 transition-colors">
          view my orders
        </a>
        <a href="/" class="inline-block text-sm border border-gray-200 rounded-full px-6 py-2 text-gray-600 hover:border-gray-400 transition-colors">
          continue shopping
        </a>
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  (function() {
    const SUPABASE_URL = document.querySelector('meta[name="supabase-url"]')?.content;
    const SUPABASE_KEY = document.querySelector('meta[name="supabase-key"]')?.content;
    const MIDTRANS_CLIENT_KEY = document.querySelector('meta[name="midtrans-client-key"]')?.content;

    function getUser() {
      try { return JSON.parse(localStorage.getItem('sb-user')); } catch { return null; }
    }
    function getToken() { return localStorage.getItem('sb-access-token'); }

    const user = getUser();
    const params = new URLSearchParams(window.location.search);
    const orderId = params.get('id');

    if (!orderId) {
      document.getElementById('payment-loading').classList.add('hidden');
      document.getElementById('payment-error').classList.remove('hidden');
      return;
    }

    var currentOrder = null;

    function fmt(val, currency) {
      if (currency === 'IDR') return 'Rp' + Math.round(Number(val)).toLocaleString('id-ID');
      return '$' + Number(val).toFixed(2);
    }

    function fmtDual(usdVal) {
      var idr = getIdrEquivalent(Number(usdVal));
      return '$' + Number(usdVal).toFixed(2) + ' / Rp' + Math.round(idr).toLocaleString('id-ID');
    }

    async function loadOrder() {
      try {
        var headers = { 'apikey': SUPABASE_KEY };
        var token = getToken();
        if (token) {
          headers['Authorization'] = 'Bearer ' + token;
        } else {
          headers['Authorization'] = 'Bearer ' + SUPABASE_KEY;
        }

        var res = await fetch(
          SUPABASE_URL + '/rest/v1/orders?id=eq.' + orderId + '&select=*,order_items(*)',
          { headers: headers }
        );
        var data = await res.json();

        if (!data || data.length === 0) {
          document.getElementById('payment-loading').classList.add('hidden');
          document.getElementById('payment-error').classList.remove('hidden');
          return;
        }

        currentOrder = data[0];

        if (currentOrder.status === 'confirmed' || currentOrder.status === 'shipped' || currentOrder.status === 'delivered') {
          document.getElementById('payment-loading').classList.add('hidden');
          document.getElementById('payment-success').classList.remove('hidden');
          document.getElementById('pay-success-id').textContent = currentOrder.display_id || ('order #' + currentOrder.id.slice(0, 8));
          if (user) document.getElementById('pay-view-orders').classList.remove('hidden');
          return;
        }

        if (currentOrder.status === 'cancelled') {
          document.getElementById('payment-loading').classList.add('hidden');
          document.getElementById('payment-error').classList.remove('hidden');
          return;
        }

        renderPaymentPage(currentOrder);
      } catch (err) {
        console.error('load order error:', err);
        document.getElementById('payment-loading').classList.add('hidden');
        document.getElementById('payment-error').classList.remove('hidden');
      }
    }

    function renderPaymentPage(order) {
      document.getElementById('payment-loading').classList.add('hidden');
      document.getElementById('payment-content').classList.remove('hidden');

      var cur = order.currency;

      document.getElementById('pay-order-id').textContent = order.display_id || ('order #' + order.id.slice(0, 8));
      document.getElementById('pay-status').textContent = order.status;

      var itemsEl = document.getElementById('pay-items');
      itemsEl.innerHTML = (order.order_items || []).map(function(item) {
        return '<div class="flex justify-between text-sm">' +
          '<span class="text-gray-600">' + item.title + ' × ' + item.quantity + '</span>' +
          '<span>' + fmt(item.price * item.quantity, cur) + '</span></div>';
      }).join('');

      document.getElementById('pay-subtotal').textContent = fmt(order.subtotal, cur);

      var promoDisc = Number(order.promo_discount) || 0;
      var totalDisc = Number(order.discount) || 0;
      var volumeDisc = totalDisc - promoDisc;
      if (volumeDisc > 0) {
        document.getElementById('pay-discount-row').classList.remove('hidden');
        document.getElementById('pay-discount').textContent = '-' + fmt(volumeDisc, cur);
      }
      if (promoDisc > 0 && order.promo_code) {
        document.getElementById('pay-promo-row').classList.remove('hidden');
        document.getElementById('pay-promo-label').textContent = 'promo (' + order.promo_code + ')';
        document.getElementById('pay-promo-discount').textContent = '-' + fmt(promoDisc, cur);
      }
      document.getElementById('pay-shipping').textContent = Number(order.shipping_fee) > 0 ? fmt(order.shipping_fee, cur) : 'free';
      document.getElementById('pay-total').textContent = fmt(order.total, cur);

      document.getElementById('pay-ship-name').textContent = order.shipping_name;
      document.getElementById('pay-ship-address').textContent = order.shipping_address;

      if (!MIDTRANS_CLIENT_KEY) {
        document.getElementById('midtrans-notice').classList.remove('hidden');
      }

      document.getElementById('pay-btn').addEventListener('click', handlePay);
    }

    async function handlePay() {
      var btn = document.getElementById('pay-btn');
      var errorEl = document.getElementById('pay-error');
      errorEl.classList.add('hidden');
      btn.textContent = 'processing...';
      btn.disabled = true;

      if (!SUPABASE_URL || !SUPABASE_KEY) {
        showGatewayPending();
        return;
      }

      try {
        var token = getToken();
        var res = await fetch(SUPABASE_URL + '/functions/v1/create-payment', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'apikey': SUPABASE_KEY,
            'Authorization': 'Bearer ' + (token || SUPABASE_KEY),
          },
          body: JSON.stringify({
            order_id: currentOrder.id,
            payment_method: document.querySelector('input[name="payment-method"]:checked')?.value || 'credit_card',
          }),
        });

        var result = await res.json();

        if (result.snap_token && window.snap) {
          window.snap.pay(result.snap_token, {
            onSuccess: function() {
              document.getElementById('payment-content').classList.add('hidden');
              document.getElementById('payment-success').classList.remove('hidden');
              document.getElementById('pay-success-id').textContent = currentOrder.display_id || ('order #' + currentOrder.id.slice(0, 8));
              if (user) document.getElementById('pay-view-orders').classList.remove('hidden');
            },
            onPending: function() {
              document.getElementById('payment-content').classList.add('hidden');
              document.getElementById('payment-pending').classList.remove('hidden');
            },
            onError: function() {
              errorEl.textContent = 'payment failed. please try again.';
              errorEl.classList.remove('hidden');
              btn.textContent = 'pay now';
              btn.disabled = false;
            },
            onClose: function() {
              btn.textContent = 'pay now';
              btn.disabled = false;
            }
          });
        } else {
          showGatewayPending();
        }
      } catch (err) {
        console.error('payment error:', err);
        showGatewayPending();
      }
    }

    function showGatewayPending() {
      var btn = document.getElementById('pay-btn');
      btn.textContent = 'pay now';
      btn.disabled = false;
      document.getElementById('midtrans-notice').classList.remove('hidden');
      document.getElementById('payment-content').classList.add('hidden');
      document.getElementById('payment-pending').classList.remove('hidden');
    }

    if (SUPABASE_URL && SUPABASE_KEY) {
      loadOrder();
    } else {
      document.getElementById('payment-loading').classList.add('hidden');
      document.getElementById('payment-content').classList.remove('hidden');
      document.getElementById('midtrans-notice').classList.remove('hidden');
      document.getElementById('pay-order-id').textContent = 'demo order';
      document.getElementById('pay-total').textContent = '$0.00';
    }
  })();
</script>
