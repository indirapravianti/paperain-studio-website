---
import Layout from '../layouts/Layout.astro';
---

<Layout title="payment">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-10">
    <!-- Error state: no order data -->
    <div id="payment-error" class="hidden text-center py-20">
      <div class="w-16 h-16 bg-red-50 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
        </svg>
      </div>
      <h2 class="text-xl font-semibold mb-2">order not found</h2>
      <p class="text-gray-500 text-sm mb-6">please complete checkout first, or start a new order.</p>
      <a href="/products" class="inline-block text-sm border border-gray-200 rounded-full px-6 py-2 text-gray-600 hover:border-gray-400 transition-colors">
        back to shop
      </a>
    </div>

    <!-- Payment content -->
    <div id="payment-content" class="hidden">
      <div class="flex items-center gap-2 mb-8">
        <a href="/checkout" class="text-gray-400 hover:text-primary transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
        </a>
        <h1 class="text-2xl font-semibold">payment</h1>
      </div>

      <div class="grid md:grid-cols-5 gap-8">
        <!-- Left column: payment method -->
        <div class="md:col-span-3">
          <div class="bg-pastel-blue/15 border border-pastel-blue/30 rounded-lg p-4 mb-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-xs text-gray-400">order</p>
                <p id="pay-order-id" class="text-sm font-medium"></p>
              </div>
              <span id="pay-status-badge" class="text-xs px-3 py-1.5 rounded-full font-medium bg-yellow-100 text-yellow-700">awaiting payment</span>
            </div>
          </div>

          <!-- Payment method: credit/debit card -->
          <div class="mb-6">
            <h2 class="font-medium mb-4">payment method</h2>
            <div class="space-y-3" id="payment-methods">
              <label class="flex items-center gap-4 border border-primary bg-primary/5 rounded-xl p-4">
                <input type="radio" name="payment-method" value="credit_card" class="accent-primary w-4 h-4" checked />
                <div class="flex items-center gap-3 flex-1">
                  <div class="w-10 h-10 bg-gray-50 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm font-medium">credit / debit card</p>
                    <p class="text-xs text-gray-400">visa, mastercard, jcb — powered by midtrans</p>
                  </div>
                </div>
              </label>
            </div>
          </div>

          <!-- International currency disclosure -->
          <div class="mb-6 bg-buttermilk/40 border border-buttermilk rounded-xl p-4">
            <div class="flex items-start gap-3">
              <div class="w-9 h-9 shrink-0 bg-pastel-blue/30 rounded-lg flex items-center justify-center mt-0.5">
                <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-primary mb-1">international card payment</p>
                <p class="text-xs text-gray-600 leading-relaxed mb-3">
                  prices on this site are shown in USD. your payment is processed by Midtrans in
                  <strong class="font-medium text-primary">Indonesian Rupiah (IDR)</strong>.
                  your bank will convert the charge using its exchange rate at the time of payment — the final amount on your statement may differ slightly from the estimate below.
                </p>
                <p id="pay-idr-estimate" class="text-xs text-primary/80 bg-white/60 rounded-lg px-3 py-2 mb-3 font-medium"></p>
                <label class="flex items-start gap-3 cursor-pointer group">
                  <input type="checkbox" id="currency-ack" class="mt-0.5 accent-primary w-4 h-4 shrink-0 rounded border-gray-300" />
                  <span class="text-xs text-gray-600 leading-relaxed group-hover:text-gray-800 transition-colors">
                    i understand my card will be charged in IDR at my bank's prevailing exchange rate, and the USD total shown is an estimate only.
                  </span>
                </label>
              </div>
            </div>
          </div>

          <div id="pay-error-msg" class="hidden text-sm text-red-500 bg-red-50 border border-red-100 rounded-lg p-3 mb-4"></div>

          <button id="pay-btn" disabled
            class="w-full bg-primary text-white py-3.5 rounded-lg text-sm font-medium hover:bg-primary/80 transition-colors disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:bg-primary">
            pay now
          </button>
          <p class="text-xs text-gray-400 text-center mt-3">
            secured by <span class="font-medium text-gray-500">midtrans</span> payment gateway
          </p>
        </div>

        <!-- Right column: order summary -->
        <div class="md:col-span-2">
          <div class="bg-gray-50 rounded-xl p-6 sticky top-24">
            <h2 class="font-medium mb-4">order summary</h2>
            <div id="pay-items" class="space-y-3 mb-4"></div>

            <div class="border-t border-gray-200 pt-4 space-y-2">
              <div class="flex justify-between text-sm">
                <span class="text-gray-500">subtotal</span>
                <span id="pay-subtotal" class="text-gray-600"></span>
              </div>
              <div id="pay-discount-row" class="flex justify-between text-sm text-green-600 hidden">
                <span>discount (20%)</span>
                <span id="pay-discount"></span>
              </div>
              <div class="flex justify-between text-sm">
                <span class="text-gray-500">shipping</span>
                <span id="pay-shipping" class="text-gray-600"></span>
              </div>
              <div class="flex justify-between font-medium border-t border-gray-200 pt-2">
                <span>total</span>
                <span id="pay-total"></span>
              </div>
            </div>

            <div class="border-t border-gray-200 pt-4 mt-4">
              <p class="text-xs text-gray-400 mb-2">shipping to</p>
              <p id="pay-ship-name" class="text-sm font-medium"></p>
              <p id="pay-ship-email" class="text-sm text-gray-500 mt-0.5"></p>
              <p id="pay-ship-address" class="text-sm text-gray-500 mt-0.5 whitespace-pre-line"></p>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-8 text-center">
        <a href="/products" class="inline-block text-sm border border-gray-200 rounded-full px-6 py-2 text-gray-600 hover:border-gray-400 transition-colors">
          continue shopping
        </a>
      </div>
    </div>

    <!-- Payment success state -->
    <div id="payment-success" class="hidden text-center py-20">
      <div class="w-20 h-20 bg-green-50 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-10 h-10 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h2 class="text-2xl font-semibold mb-2">payment successful!</h2>
      <p class="text-gray-500 text-sm mb-2">thank you for your order.</p>
      <p class="text-gray-400 text-xs mb-8">order <span id="success-order-id" class="font-medium text-gray-600"></span></p>
      <p class="text-gray-500 text-sm mb-8">we'll send a confirmation email shortly. you can track your order from your account page.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/products" class="inline-block text-sm border border-gray-200 rounded-full px-6 py-2 text-gray-600 hover:border-gray-400 transition-colors">
          continue shopping
        </a>
        <a href="/account" class="inline-block text-sm bg-primary text-white rounded-full px-6 py-2 hover:bg-primary/80 transition-colors">
          view my orders
        </a>
      </div>
    </div>

    <!-- Payment pending state -->
    <div id="payment-pending" class="hidden text-center py-20">
      <div class="w-20 h-20 bg-yellow-50 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-10 h-10 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <h2 class="text-2xl font-semibold mb-2">payment pending</h2>
      <p class="text-gray-500 text-sm mb-2">your payment is being processed.</p>
      <p class="text-gray-400 text-xs mb-8">order <span id="pending-order-id" class="font-medium text-gray-600"></span></p>
      <p class="text-gray-500 text-sm mb-8">we'll update you via email once the payment is confirmed.</p>
      <a href="/products" class="inline-block text-sm border border-gray-200 rounded-full px-6 py-2 text-gray-600 hover:border-gray-400 transition-colors">
        continue shopping
      </a>
    </div>
  </section>
</Layout>

<script is:inline>
  (function() {
    var SUPABASE_URL = document.querySelector('meta[name="supabase-url"]')?.content;
    var SUPABASE_KEY = document.querySelector('meta[name="supabase-key"]')?.content;

    var data = null;
    try {
      data = JSON.parse(sessionStorage.getItem('paperain-pending-payment'));
    } catch {}

    if (!data || !data.items || !data.items.length) {
      document.getElementById('payment-error').classList.remove('hidden');
      return;
    }

    var USD_TO_IDR = 16000;

    function fmt(val) {
      return '$' + Number(val).toFixed(2);
    }

    function fmtIdr(usd) {
      return 'Rp' + Math.round(Number(usd) * USD_TO_IDR).toLocaleString('id-ID');
    }

    // Show order summary
    document.getElementById('payment-content').classList.remove('hidden');
    document.getElementById('pay-order-id').textContent = data.order.display_id || data.order.id || '';

    var itemsEl = document.getElementById('pay-items');
    itemsEl.innerHTML = (data.items || []).map(function(item) {
      var lineTotal = (item.price || 0) * item.qty;
      return '<div class="flex justify-between text-sm">' +
        '<span class="text-gray-600">' + item.title + ' &times; ' + item.qty + '</span>' +
        '<span>' + fmt(lineTotal) + '</span></div>';
    }).join('') || '<p class="text-sm text-gray-400">no items</p>';

    var s = data.summary || {};
    document.getElementById('pay-subtotal').textContent = fmt(s.subtotal || 0);

    if ((s.volumeDiscount || 0) > 0) {
      document.getElementById('pay-discount-row').classList.remove('hidden');
      document.getElementById('pay-discount').textContent = '-' + fmt(s.volumeDiscount);
    }
    document.getElementById('pay-shipping').textContent = fmt(s.shipping || 0);
    document.getElementById('pay-total').textContent = fmt(s.total || 0);

    var idrEstimateEl = document.getElementById('pay-idr-estimate');
    if (idrEstimateEl && s.total) {
      idrEstimateEl.textContent = 'estimated charge: ≈ ' + fmtIdr(s.total) + ' IDR (via Midtrans)';
    }

    if (data.shipping) {
      document.getElementById('pay-ship-name').textContent = data.shipping.name || '';
      document.getElementById('pay-ship-email').textContent = data.shipping.email || '';
      document.getElementById('pay-ship-address').textContent = data.shipping.address || '';
    }

    // Payment logic
    var payBtn = document.getElementById('pay-btn');
    var currencyAck = document.getElementById('currency-ack');
    var errorMsg = document.getElementById('pay-error-msg');
    var isProcessing = false;

    currencyAck.addEventListener('change', function() {
      payBtn.disabled = !currencyAck.checked;
    });

    function showError(msg) {
      errorMsg.textContent = msg;
      errorMsg.classList.remove('hidden');
    }

    function hideError() {
      errorMsg.classList.add('hidden');
    }

    function showSuccess(orderId) {
      document.getElementById('payment-content').classList.add('hidden');
      document.getElementById('payment-success').classList.remove('hidden');
      document.getElementById('success-order-id').textContent = orderId;
      sessionStorage.removeItem('paperain-pending-payment');
    }

    function showPending(orderId) {
      document.getElementById('payment-content').classList.add('hidden');
      document.getElementById('payment-pending').classList.remove('hidden');
      document.getElementById('pending-order-id').textContent = orderId;
      sessionStorage.removeItem('paperain-pending-payment');
    }

    function parseApiError(text, json, status) {
      if (text && text.indexOf('<!DOCTYPE') !== -1) {
        if (status === 502) {
          return 'payment server error (502). wait a minute, then try again. if it persists, check Vercel deployment logs.';
        }
        return 'payment server error. please try again in a few minutes.';
      }
      var msg = (json && (json.error || json.message)) || ('request failed (' + status + ')');
      if (json && json.detail && json.detail.error_messages) {
        msg = json.detail.error_messages.join(', ');
      }
      return msg;
    }

    async function callApi(endpoint, payload) {
      var url = '/api/' + endpoint;
      try {
        var res = await fetch(url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        var text = await res.text();
        var json = {};
        try { json = text ? JSON.parse(text) : {}; } catch { json = {}; }
        if (!res.ok) {
          throw new Error(parseApiError(text, json, res.status));
        }
        return json;
      } catch (e) {
        if (e && e.message === 'Failed to fetch') {
          throw new Error(
            'could not reach the payment server. use www.paperainstudio.com and redeploy Vercel after env var changes.'
          );
        }
        throw e;
      }
    }

    payBtn.addEventListener('click', async function() {
      if (isProcessing) return;
      if (!currencyAck.checked) {
        showError('please confirm the international payment notice before continuing.');
        return;
      }
      isProcessing = true;
      hideError();
      payBtn.textContent = 'processing...';
      payBtn.classList.add('opacity-70', 'cursor-not-allowed');

      try {
        // Step 1: Place order in database
        var user = null;
        try { user = JSON.parse(localStorage.getItem('sb-user')); } catch {}

        var orderPayload = {
          items: data.items.map(function(item) {
            if (!item.id) {
              throw new Error('cart item missing product id. please go back to checkout and try again.');
            }
            return { id: item.id, title: item.title, qty: item.qty, image: item.image || '' };
          }),
          currency: 'USD',
          shipping_name: data.shipping.name,
          shipping_email: data.shipping.email,
          shipping_phone: data.shipping.phone,
          shipping_address: data.shipping.address,
          shipping_country: data.shipping.country || 'OTHER',
          notes: data.notes || null,
          customer_id: user ? user.id : null,
        };

        var orderResult = await callApi('place-order', orderPayload);
        var order = orderResult.order;

        if (!order || !order.id) {
          throw new Error('failed to create order');
        }

        // Update display ID
        var displayId = order.display_id || order.id.slice(0, 8);
        document.getElementById('pay-order-id').textContent = displayId;

        // Step 2: Create payment token
        var paymentResult = await callApi('create-payment', { order_id: order.id });

        if (!paymentResult.snap_token) {
          throw new Error('failed to create payment token');
        }

        // Step 3: Open Midtrans Snap popup
        if (typeof window.snap === 'undefined') {
          throw new Error('payment gateway is not loaded. please refresh and try again.');
        }

        window.snap.pay(paymentResult.snap_token, {
          onSuccess: function(result) {
            console.log('Payment success:', result);
            showSuccess(displayId);
          },
          onPending: function(result) {
            console.log('Payment pending:', result);
            showPending(displayId);
          },
          onError: function(result) {
            console.error('Payment error:', result);
            showError('payment was declined. please try again or use a different card.');
            payBtn.textContent = 'try again';
            payBtn.classList.remove('opacity-70', 'cursor-not-allowed');
            isProcessing = false;
          },
          onClose: function() {
            payBtn.textContent = 'pay now';
            payBtn.classList.remove('opacity-70', 'cursor-not-allowed');
            isProcessing = false;
          },
        });

      } catch (err) {
        console.error('Payment flow error:', err);
        showError(err.message || 'something went wrong. please try again.');
        payBtn.textContent = 'pay now';
        payBtn.classList.remove('opacity-70', 'cursor-not-allowed');
        isProcessing = false;
      }
    });
  })();
</script>
