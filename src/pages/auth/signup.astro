---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="sign up">
  <section class="max-w-md mx-auto px-4 py-16 text-center">
    <div class="w-16 h-16 bg-pastel-blue/30 rounded-full flex items-center justify-center mx-auto mb-6">
      <svg class="w-8 h-8 text-burgundy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
    </div>
    <h1 class="text-2xl font-semibold mb-3">coming soon</h1>
    <p class="text-sm text-gray-500 leading-relaxed mb-8">
      we're getting things ready! account registration<br/>will be available soon. stay tuned.
    </p>
    <div class="flex justify-center gap-3">
      <a href="/" class="inline-block text-sm border border-gray-200 rounded-full px-6 py-2 text-gray-600 hover:border-gray-400 transition-colors">
        back to home
      </a>
      <a href="/products" class="inline-block text-sm bg-burgundy text-white rounded-full px-6 py-2 hover:bg-burgundy/80 transition-colors">
        browse products
      </a>
    </div>
  </section>
</Layout>
