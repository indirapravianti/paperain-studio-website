---
import Layout from '../../layouts/Layout.astro';
import products from '../../data/products.json';
import ProductCard from '../../components/ProductCard.astro';
import { getIdrPriceForCategory } from '../../lib/idr-prices.js';

export function getStaticPaths() {
  return products.filter(p => p.isActive).map(product => ({
    params: { id: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const productIdrPrice = getIdrPriceForCategory(product.category);

const related = products
  .filter(p => p.isActive && p.category === product.category && p.id !== product.id)
  .slice(0, 4);

const categoryLabels: Record<string, string> = {
  'sticker sheet': 'Sticker Sheet',
  keychain: 'Keychain',
  griptok: 'Griptok',
  artprint: 'Art Print',
  'greeting card': 'Greeting Card',
  postcard: 'Postcard',
  phonestrap: 'Phone Strap',
};

const hasVariants = product.variants && product.variants.length > 0;
const productImages = product.images && product.images.length > 0 ? product.images : [product.image];
const hasMultipleImages = productImages.length > 1;

---

<Layout title={product.title}>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-400 mb-8">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <a href="/products" class="hover:text-primary">Products</a>
      <span class="mx-2">/</span>
      <span class="text-gray-600">{product.title}</span>
    </nav>

    <div class="grid md:grid-cols-2 gap-8 lg:gap-12">
      <!-- Image Gallery -->
      <div>
        <div class="aspect-square rounded-2xl overflow-hidden bg-gray-50">
          <img id="product-image" src={product.image} alt={product.title} class="w-full h-full object-cover" />
        </div>
        {hasMultipleImages && (
          <div class="flex gap-3 mt-3" id="image-thumbnails">
            {productImages.map((img: string, index: number) => (
              <button
                class:list={[
                  'thumb-btn w-16 h-16 sm:w-20 sm:h-20 rounded-lg overflow-hidden border-2 transition-all',
                  index === 0 ? 'border-primary' : 'border-transparent hover:border-gray-300'
                ]}
                data-image={img}
              >
                <img src={img} alt={`${product.title} ${index + 1}`} class="w-full h-full object-cover" />
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- Details -->
      <div class="flex flex-col justify-center">
        <span class="text-xs uppercase tracking-wider text-accent font-medium mb-2">
          {categoryLabels[product.category] || product.category}
        </span>
        <h1 class="text-2xl sm:text-3xl font-semibold mb-3">{product.title}</h1>
        <div class="mb-6">
          <p class="text-2xl font-medium text-gray-800 product-price" data-idr={productIdrPrice} data-category={product.category}>Rp{productIdrPrice.toLocaleString('id-ID')}</p>
          <p id="stock-status" class="text-sm mt-2 hidden"></p>
        </div>

        {product.description ? (
          <p class="text-gray-500 text-sm leading-relaxed mb-8 whitespace-pre-line">{product.description}</p>
        ) : (
          <p class="text-gray-400 text-sm italic mb-8">Description coming soon.</p>
        )}

        {/* Variant Selector */}
        {hasVariants && (
          <div class="mb-6">
            <p class="text-sm font-medium text-gray-700 mb-3">variant</p>
            <div class="flex flex-wrap gap-2" id="variant-selector">
              {product.variants.map((variant: any, index: number) => (
                <button
                  class:list={[
                    'variant-btn text-sm px-4 py-2 rounded-full border transition-colors',
                    index === 0 ? 'bg-primary text-white border-primary' : 'border-gray-200 text-gray-600 hover:border-gray-400'
                  ]}
                  data-variant-image={variant.image}
                  data-variant-id={variant.id}
                  data-variant-label={variant.label}
                >
                  {variant.label}
                </button>
              ))}
            </div>
          </div>
        )}

        <!-- Quantity + Add to Cart -->
        <div class="flex items-center gap-4 mb-6">
          <div class="flex items-center border border-gray-200 rounded-lg">
            <button id="qty-minus" class="px-3 py-2 text-gray-400 hover:text-primary transition-colors">−</button>
            <span id="qty-value" class="px-3 py-2 text-sm font-medium min-w-[2rem] text-center">1</span>
            <button id="qty-plus" class="px-3 py-2 text-gray-400 hover:text-primary transition-colors">+</button>
          </div>
          <button
            id="add-to-cart-btn"
            class="flex-1 bg-primary text-white py-3 rounded-lg hover:bg-primary/80 transition-colors text-sm font-medium disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Add to Cart
          </button>
        </div>

        <div class="border-t border-gray-100 pt-6">
          <div class="flex items-center gap-2 text-sm text-gray-500" id="volume-discount-hint">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
            </svg>
            <span>Spend Rp80.000+ to get 20% off!</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Related Products -->
    {related.length > 0 && (
      <div class="mt-20">
        <h2 class="text-xl font-semibold mb-6">you might also like</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 sm:gap-6">
          {related.map(p => (
            <ProductCard id={p.id} title={p.title} price={p.price} image={p.image} isNew={p.isNew} category={p.category} />
          ))}
        </div>
      </div>
    )}
  </section>
</Layout>

<script is:inline define:vars={{ productData: JSON.stringify({ id: product.id, title: product.title, price: product.price, priceIdr: productIdrPrice, image: product.image, category: product.category, variants: product.variants || [] }) }}>
  (function() {
    const product = JSON.parse(productData);
    let qty = 1;
    let selectedVariant = product.variants.length > 0 ? product.variants[0] : null;
    let stockInfo = null;
    const qtyEl = document.getElementById('qty-value');
    const productImage = document.getElementById('product-image');
    const addBtn = document.getElementById('add-to-cart-btn');
    const stockEl = document.getElementById('stock-status');

    function updateVolumeHint() {
      var hint = document.getElementById('volume-discount-hint');
      if (!hint) return;
      hint.querySelector('span').textContent = 'Spend Rp80.000+ to get 20% off!';
    }

    function applyStockUI() {
      if (!stockInfo) return;
      stockEl.classList.remove('hidden');
      if (stockInfo.status === 'restocking') {
        stockEl.textContent = 'currently restocking — check back soon';
        stockEl.className = 'text-sm mt-2 text-amber-600';
        addBtn.disabled = true;
        addBtn.textContent = 'restocking';
      } else if (!stockInfo.purchasable) {
        stockEl.textContent = 'out of stock';
        stockEl.className = 'text-sm mt-2 text-red-500';
        addBtn.disabled = true;
        addBtn.textContent = 'out of stock';
      } else if (stockInfo.available != null && stockInfo.available <= 3) {
        stockEl.textContent = 'only ' + stockInfo.available + ' left in stock';
        stockEl.className = 'text-sm mt-2 text-orange-600';
      } else {
        stockEl.classList.add('hidden');
      }
    }

    fetch('/api/stock?ids=' + encodeURIComponent(product.id))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        stockInfo = data.stock && data.stock[product.id];
        applyStockUI();
      })
      .catch(function() {});

    document.addEventListener('DOMContentLoaded', function() {
      updateVolumeHint();
      if (typeof applyProductPrices === 'function') applyProductPrices();
    });

    document.getElementById('qty-minus').addEventListener('click', () => {
      if (qty > 1) { qty--; qtyEl.textContent = qty; }
    });

    document.getElementById('qty-plus').addEventListener('click', () => {
      qty++;
      qtyEl.textContent = qty;
    });

    // Image thumbnails
    const thumbBtns = document.querySelectorAll('.thumb-btn');
    thumbBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        thumbBtns.forEach(b => {
          b.classList.remove('border-primary');
          b.classList.add('border-transparent');
        });
        btn.classList.add('border-primary');
        btn.classList.remove('border-transparent');
        productImage.src = btn.dataset.image;
      });
    });

    // Variant buttons
    const variantBtns = document.querySelectorAll('.variant-btn');
    variantBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        variantBtns.forEach(b => {
          b.classList.remove('bg-primary', 'text-white', 'border-primary');
          b.classList.add('border-gray-200', 'text-gray-600');
        });
        btn.classList.add('bg-primary', 'text-white', 'border-primary');
        btn.classList.remove('border-gray-200', 'text-gray-600');

        productImage.src = btn.dataset.variantImage;
        selectedVariant = {
          id: btn.dataset.variantId,
          label: btn.dataset.variantLabel,
          image: btn.dataset.variantImage
        };
      });
    });

    document.getElementById('add-to-cart-btn').addEventListener('click', () => {
      if (stockInfo && !stockInfo.purchasable) return;
      const cartId = selectedVariant ? selectedVariant.id : product.id;
      const cartTitle = selectedVariant ? product.title + ' - ' + selectedVariant.label : product.title;
      const cartImage = selectedVariant ? selectedVariant.image : product.image;

      addToCart({
        id: cartId,
        title: cartTitle,
        price: product.price,
        priceUsd: product.price,
        priceIdr: product.priceIdr,
        image: cartImage,
        category: product.category,
        qty: qty,
      });
    });
  })();
</script>
