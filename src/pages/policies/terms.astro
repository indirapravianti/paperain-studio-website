---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Terms & Conditions">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-16">
    <h1 class="text-3xl font-semibold mb-8">Terms & Conditions</h1>
    <div class="prose prose-gray max-w-none text-sm leading-relaxed text-gray-600 space-y-6">
      <p>By accessing and using this website, you agree to the following terms and conditions.</p>

      <h2 class="text-lg font-medium text-gray-800">Orders</h2>
      <p>All orders are subject to availability. We reserve the right to refuse any order.</p>

      <h2 class="text-lg font-medium text-gray-800">Pricing</h2>
      <p>Prices are listed in USD and are subject to change without notice.</p>

      <h2 class="text-lg font-medium text-gray-800">Intellectual Property</h2>
      <p>All designs and content on this website are the property of Paperain Studio and may not be reproduced without permission.</p>

      <p class="text-gray-400 italic">This is placeholder content. Please update with your actual terms.</p>
    </div>
  </section>
</Layout>
