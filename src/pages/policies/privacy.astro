---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Privacy Policy">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-16">
    <h1 class="text-3xl font-semibold mb-8">Privacy Policy</h1>
    <div class="prose prose-gray max-w-none text-sm leading-relaxed text-gray-600 space-y-6">
      <p>Your privacy is important to us. This policy explains how we collect, use, and protect your personal information.</p>

      <h2 class="text-lg font-medium text-gray-800">Information We Collect</h2>
      <p>We collect your name, email address, phone number, and shipping address when you place an order.</p>

      <h2 class="text-lg font-medium text-gray-800">How We Use Your Information</h2>
      <p>Your information is used solely to process and ship your orders, and to communicate with you about your purchases.</p>

      <h2 class="text-lg font-medium text-gray-800">Data Protection</h2>
      <p>We do not sell or share your personal information with third parties.</p>

    </div>
  </section>
</Layout>
