---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-16">
    <h1 class="text-3xl font-semibold mb-8 text-center">About Paperain Studio</h1>

    <div class="prose prose-gray max-w-none text-sm leading-relaxed text-gray-600 space-y-4">
      <p>
        Welcome to <strong>Paperain Studio</strong> — a small creative studio that designs cute and aesthetic stationery products. From stickers to keychains, griptoks to greeting cards, everything is designed with love and care.
      </p>
      <p>
        We believe that little things can brighten your day. Whether it's decorating your journal, personalizing your phone, or sending a heartfelt card to someone you love — our products are made to bring joy to your everyday life.
      </p>
      <p>
        Thank you for supporting our small business! Every order means the world to us. ♡
      </p>
    </div>
  </section>
</Layout>
