---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-16">
    <div class="text-center mb-12">
      <img src="/images/logo.jpg" alt="Paperain Studio" class="w-32 h-32 mx-auto mb-6 object-contain" />
      <h1 class="text-3xl font-semibold mb-4">paperain studio</h1>
    </div>

    <div class="prose prose-gray max-w-none text-sm leading-relaxed text-gray-600 space-y-6">
      <p>
        paperain studio is an art and trinket shop established in 2020. We sell a variety of accessories and stationery, such as stickers, keychains, phone grips, artprints, greeting cards, and phone charms. Over 40,000 products have been adopted by our fellow friends, so we are very thankful for everyone's support.
      </p>

      <div>
        <h2 class="text-xl font-semibold text-primary mb-4">where to find us</h2>
        <p class="mb-4">You can find us in online stores or offline stores across Indonesia</p>
        
        <div class="grid sm:grid-cols-2 gap-x-8 gap-y-2">
          <div>
            <h3 class="text-sm font-semibold text-primary mt-4 mb-2">yogyakarta</h3>
            <ul class="space-y-1 text-sm text-gray-600">
              <li>Toko Merah Gejayan</li>
              <li>Toko Merah Gedongkuning</li>
              <li>Artlinx Store</li>
              <li>Sama Sesama</li>
              <li>Gardena Department Store</li>
              <li>Toko Buku Togamas</li>
            </ul>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-primary mt-4 mb-2">jakarta & bsd</h3>
            <ul class="space-y-1 text-sm text-gray-600">
              <li>Palette.id, ICE Business Park, BSD</li>
              <li>Palette.id, FX Sudirman 2F, Jakarta</li>
            </ul>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-primary mt-4 mb-2">central java</h3>
            <ul class="space-y-1 text-sm text-gray-600">
              <li>Toko Buku Jendela, Klaten</li>
              <li>Toko Buku Jendela, Boyolali</li>
              <li>Toko Buku Jendela, Magelang</li>
              <li>Toko Buku Jendela, Salatiga</li>
              <li>Toko Buku Jendela, Wedi</li>
              <li>Mini Jendela Jatinom, Klaten</li>
              <li>Pangsar Stationery, Purwokerto</li>
              <li>Puspita Paper & Stationery, Surakarta</li>
              <li>Toko Buku Sekawan, Surakarta</li>
            </ul>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-primary mt-4 mb-2">other cities</h3>
            <ul class="space-y-1 text-sm text-gray-600">
              <li>Bali Art Supplies, Denpasar</li>
              <li>Curated by Dejue, Semarang</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
