---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-16">
    <div class="text-center mb-12">
      <img src="/images/logo.jpg" alt="Paperain Studio" class="w-32 h-32 mx-auto mb-6 object-contain" />
      <h1 class="text-3xl font-semibold mb-4">paperain studio</h1>
    </div>

    <div class="prose prose-gray max-w-none text-sm leading-relaxed text-gray-600 space-y-6">
      <p>
        paperain studio is an art and trinket shop established in 2020. We sell a variety of accessories and stationery, such as stickers, keychains, phone grips, artprints, greeting cards, and phone charms. Over 40,000 products have been adopted by our fellow friends, so we are very thankful for everyone's support.
      </p>

      <div>
        <h2 class="text-xl font-semibold text-primary mb-4">where to find us</h2>
        <p class="mb-4">You can find us in online stores or offline stores across Indonesia</p>
        
        <div class="grid sm:grid-cols-2 gap-x-8 gap-y-2">
          <div>
            <h3 class="text-sm font-semibold text-primary mt-4 mb-2">yogyakarta</h3>
            <ul class="space-y-1 text-sm text-gray-600">
              <li>Toko Merah Gejayan</li>
              <li>Toko Merah Gedongkuning</li>
              <li>Artlinx Store</li>
              <li>Sama Sesama</li>
              <li>Gardena Department Store</li>
              <li>Toko Buku Togamas</li>
            </ul>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-primary mt-4 mb-2">jakarta & bsd</h3>
            <ul class="space-y-1 text-sm text-gray-600">
              <li>Palette.id, ICE Business Park, BSD</li>
              <li>Palette.id, FX Sudirman 2F, Jakarta</li>
            </ul>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-primary mt-4 mb-2">central java</h3>
            <ul class="space-y-1 text-sm text-gray-600">
              <li>Toko Buku Jendela, Klaten</li>
              <li>Toko Buku Jendela, Boyolali</li>
              <li>Toko Buku Jendela, Magelang</li>
              <li>Toko Buku Jendela, Salatiga</li>
              <li>Toko Buku Jendela, Wedi</li>
              <li>Mini Jendela Jatinom, Klaten</li>
              <li>Pangsar Stationery, Purwokerto</li>
              <li>Puspita Paper & Stationery, Surakarta</li>
              <li>Toko Buku Sekawan, Surakarta</li>
            </ul>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-primary mt-4 mb-2">other cities</h3>
            <ul class="space-y-1 text-sm text-gray-600">
              <li>Bali Art Supplies, Denpasar</li>
              <li>Curated by Dejue, Semarang</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Partnership Banner -->
  <section class="bg-buttermilk/40 py-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-xl font-semibold mb-3">interested to partner with us?</h2>
      <p class="text-sm text-gray-600 mb-6">we'd love to collaborate! reach out to us via email or whatsapp</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="mailto:hello@paperainstudio.com" class="inline-flex items-center gap-2 bg-burgundy text-white text-sm rounded-full px-6 py-2.5 hover:bg-burgundy/80 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          hello@paperainstudio.com
        </a>
        <a href="https://api.whatsapp.com/send?phone=62895392444965&text=Hi%20%40paperainstudio%2C%20" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-[#25D366] text-white text-sm rounded-full px-6 py-2.5 hover:bg-[#20bd5a] transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          whatsapp
        </a>
      </div>
    </div>
  </section>
</Layout>
