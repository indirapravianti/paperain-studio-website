---
import Layout from '../layouts/Layout.astro';
---

<Layout title="checkout">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-10">
    <h1 class="text-2xl font-semibold mb-8">checkout</h1>

    <div class="grid md:grid-cols-5 gap-8">
      <!-- Form -->
      <div class="md:col-span-3">
        <!-- Guest notice -->
        <!-- Auth notice hidden until registration opens -->
        <div id="auth-notice" class="hidden bg-pastel-blue/20 border border-pastel-blue rounded-lg p-4 mb-6">
          <p class="text-sm text-burgundy">
            guest checkout is available. account registration is coming soon!
          </p>
        </div>

        <form id="checkout-form" class="space-y-5">
          <div>
            <label for="name" class="block text-sm font-medium mb-1.5">full name</label>
            <input type="text" id="name" name="name" required
              class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-primary transition-colors" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium mb-1.5">email address</label>
            <input type="email" id="email" name="email" required
              class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-primary transition-colors" />
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium mb-1.5">phone number</label>
            <input type="tel" id="phone" name="phone" required
              class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-primary transition-colors" />
          </div>
          <div>
            <label for="country" class="block text-sm font-medium mb-1.5">shipping country</label>
            <select id="country" required
              class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-primary transition-colors bg-white">
              <option value="">select country</option>
              <option value="ID">Indonesia</option>
              <option value="JP">Japan</option>
              <option value="SG">Singapore</option>
              <option value="MY">Malaysia</option>
              <option value="TH">Thailand</option>
              <option value="PH">Philippines</option>
              <option value="VN">Vietnam</option>
              <option value="KR">South Korea</option>
              <option value="TW">Taiwan</option>
              <option value="HK">Hong Kong</option>
              <option value="CN">China</option>
              <option value="IN">India</option>
              <option value="AU">Australia</option>
              <option value="NZ">New Zealand</option>
              <option value="US">United States</option>
              <option value="CA">Canada</option>
              <option value="GB">United Kingdom</option>
              <option value="DE">Germany</option>
              <option value="FR">France</option>
              <option value="NL">Netherlands</option>
              <option value="OTHER">Other</option>
            </select>
          </div>
          <div>
            <label for="address" class="block text-sm font-medium mb-1.5">shipping address</label>
            <textarea id="address" name="address" rows="3" required
              class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-primary transition-colors resize-none"
              placeholder="street, city, state / province, postal code"></textarea>
          </div>
          <div>
            <label for="notes" class="block text-sm font-medium mb-1.5">order notes <span class="text-gray-400 font-normal">(optional)</span></label>
            <textarea id="notes" name="notes" rows="2"
              class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-primary transition-colors resize-none"
              placeholder="any special requests or notes"></textarea>
          </div>

          <div id="checkout-error" class="text-sm text-red-500 hidden"></div>

          <button type="submit" id="submit-btn"
            class="w-full bg-primary text-white py-3 rounded-lg hover:bg-primary/80 transition-colors text-sm font-medium mt-4">
            proceed to payment
          </button>
        </form>

        <div id="order-success" class="hidden text-center py-12">
          <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h2 class="text-xl font-semibold mb-2">order placed!</h2>
          <p class="text-gray-500 text-sm mb-2">thank you for your order. we'll send a confirmation to your email.</p>
          <p id="order-id-display" class="text-xs text-gray-400 mb-6"></p>
          <div class="flex justify-center gap-3">
            <a href="/account" id="view-orders-link" class="hidden inline-block text-sm border border-gray-200 rounded-full px-6 py-2 text-gray-600 hover:border-gray-400 transition-colors">
              view my orders
            </a>
            <a href="/" class="inline-block text-sm border border-gray-200 rounded-full px-6 py-2 text-gray-600 hover:border-gray-400 transition-colors">
              continue shopping
            </a>
          </div>
        </div>
      </div>

      <!-- Order Summary -->
      <div class="md:col-span-2">
        <div class="bg-gray-50 rounded-xl p-6 sticky top-24">
          <h2 class="font-medium mb-4">order summary</h2>
          <div id="checkout-items" class="space-y-3 mb-4"></div>

          <div class="border-t border-gray-200 pt-4 mb-4">
            <label for="promo-code" class="block text-sm font-medium mb-1.5">promo code</label>
            <div class="flex gap-2">
              <input type="text" id="promo-code" autocomplete="off"
                class="flex-1 border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary transition-colors uppercase"
                placeholder="enter code" />
              <button type="button" id="promo-apply-btn"
                class="shrink-0 border border-gray-200 rounded-lg px-4 py-2 text-sm hover:border-primary hover:text-primary transition-colors">
                apply
              </button>
            </div>
            <p id="promo-message" class="text-xs mt-1.5 hidden"></p>
          </div>

          <div class="border-t border-gray-200 pt-4 space-y-2">
            <div id="checkout-discount-row" class="flex justify-between text-sm text-green-600 hidden">
              <span>discount (20%)</span>
              <span id="checkout-discount">-$0.00</span>
            </div>
            <div id="checkout-promo-row" class="flex justify-between text-sm text-green-600 hidden">
              <span id="checkout-promo-label">promo</span>
              <span id="checkout-promo-discount">-$0.00</span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-500">shipping</span>
              <span id="checkout-shipping" class="text-gray-600">—</span>
            </div>
            <div class="flex justify-between font-medium border-t border-gray-200 pt-2">
              <span>total</span>
              <span id="checkout-total">$0.00</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
    (function() {
      const SUPABASE_URL = document.querySelector('meta[name="supabase-url"]')?.content;
      const SUPABASE_KEY = document.querySelector('meta[name="supabase-key"]')?.content;

      function getUser() {
        try { return JSON.parse(localStorage.getItem('sb-user')); } catch { return null; }
      }
      function getToken() { return localStorage.getItem('sb-access-token'); }

      const cart = getCart();
    const container = document.getElementById('checkout-items');
    const totalEl = document.getElementById('checkout-total');
    const discountRow = document.getElementById('checkout-discount-row');
    const discountEl = document.getElementById('checkout-discount');
    const promoRow = document.getElementById('checkout-promo-row');
    const promoLabel = document.getElementById('checkout-promo-label');
    const promoDiscountEl = document.getElementById('checkout-promo-discount');
    const promoMessageEl = document.getElementById('promo-message');
    const promoCodeInput = document.getElementById('promo-code');
    const promoApplyBtn = document.getElementById('promo-apply-btn');
    const shippingEl = document.getElementById('checkout-shipping');
    const errorEl = document.getElementById('checkout-error');
    const user = getUser();

    var appliedPromo = null;

    var SHIPPING_FEE_USD = 3;
    var SHIPPING_FEE_IDR = 48000;

    // Show auth notice for guests
    if (!user) {
      document.getElementById('auth-notice').classList.remove('hidden');
    } else {
      prefillProfile();
    }

    async function prefillProfile() {
      if (!SUPABASE_URL || !SUPABASE_KEY || !user) return;
      try {
        const res = await fetch(`${SUPABASE_URL}/rest/v1/customers?id=eq.${user.id}&select=*`, {
          headers: { 'apikey': SUPABASE_KEY, 'Authorization': getApiAuthHeader() },
        });
        const data = await res.json();
        if (data && data.length > 0) {
          const c = data[0];
          if (c.full_name) document.getElementById('name').value = c.full_name;
          if (c.email) document.getElementById('email').value = c.email;
          if (c.phone) document.getElementById('phone').value = c.phone;
          if (c.address) document.getElementById('address').value = c.address;
        }
      } catch {}
    }

    var currency = detectCurrency();

    function fmtDual(usd, idr) {
      return '$' + usd.toFixed(2) + ' / Rp' + Math.round(idr).toLocaleString('id-ID');
    }

    function fmtTotal(val) {
      if (currency === 'IDR') return 'Rp' + Math.round(val).toLocaleString('id-ID');
      return '$' + val.toFixed(2);
    }

    // Calculate item subtotals in both currencies
    var itemSubtotalUsd = 0;
    var itemSubtotalIdr = 0;
    if (cart.length === 0) {
      container.innerHTML = '<p class="text-sm text-gray-400">your cart is empty.</p>';
      document.getElementById('submit-btn').disabled = true;
      document.getElementById('submit-btn').classList.add('opacity-50', 'cursor-not-allowed');
    } else {
      container.innerHTML = cart.map(item => {
        var idr = getIdrEquivalent(item.price, item.category);
        itemSubtotalUsd += item.price * item.qty;
        itemSubtotalIdr += idr * item.qty;
        return `
          <div class="flex justify-between text-sm">
            <span class="text-gray-600">${item.title} × ${item.qty}</span>
            <span>${fmtDual(item.price * item.qty, idr * item.qty)}</span>
          </div>`;
      }).join('');
    }

    function getVolumeDiscountUsd() {
      return itemSubtotalUsd >= 50 ? itemSubtotalUsd * 0.2 : 0;
    }
    function getVolumeDiscountIdr() {
      return itemSubtotalIdr >= 500000 ? itemSubtotalIdr * 0.2 : 0;
    }

    function getPromoDiscount() {
      return appliedPromo ? appliedPromo.discount_amount : 0;
    }

    function updateTotals() {
      var volDiscUsd = getVolumeDiscountUsd();
      var volDiscIdr = getVolumeDiscountIdr();
      var promoDiscount = getPromoDiscount();
      var shippingUsd = cart.length > 0 ? SHIPPING_FEE_USD : 0;
      var shippingIdr = cart.length > 0 ? SHIPPING_FEE_IDR : 0;

      if (volDiscUsd > 0) {
        discountRow.classList.remove('hidden');
        discountEl.textContent = '-' + fmtDual(volDiscUsd, volDiscIdr);
      } else {
        discountRow.classList.add('hidden');
      }

      if (promoDiscount > 0 && appliedPromo) {
        promoRow.classList.remove('hidden');
        promoLabel.textContent = 'promo (' + appliedPromo.code + ')';
        promoDiscountEl.textContent = '-' + fmtTotal(promoDiscount);
      } else {
        promoRow.classList.add('hidden');
      }

      if (cart.length > 0) {
        shippingEl.textContent = fmtDual(shippingUsd, shippingIdr);
        var totalUsd = itemSubtotalUsd - volDiscUsd - (currency === 'USD' ? promoDiscount : 0) + shippingUsd;
        var totalIdr = itemSubtotalIdr - volDiscIdr - (currency === 'IDR' ? promoDiscount : 0) + shippingIdr;
        totalEl.textContent = fmtDual(totalUsd, totalIdr);
      } else {
        shippingEl.textContent = '—';
        totalEl.textContent = fmtDual(0, 0);
      }
    }

    function setPromoMessage(text, isError) {
      if (!text) {
        promoMessageEl.classList.add('hidden');
        promoMessageEl.textContent = '';
        return;
      }
      promoMessageEl.textContent = text;
      promoMessageEl.classList.remove('hidden');
      promoMessageEl.className = 'text-xs mt-1.5 ' + (isError ? 'text-red-500' : 'text-green-600');
    }

    async function applyPromoCode() {
      var code = promoCodeInput.value.trim();
      if (!code) {
        appliedPromo = null;
        setPromoMessage('enter a promo code', true);
        updateTotals();
        return;
      }

      if (!SUPABASE_URL || !SUPABASE_KEY) {
        setPromoMessage('promo codes are not available in demo mode', true);
        return;
      }

      promoApplyBtn.disabled = true;
      promoApplyBtn.textContent = 'checking...';
      setPromoMessage('', false);

      try {
        var res = await fetch(SUPABASE_URL + '/functions/v1/validate-promo', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'apikey': SUPABASE_KEY,
            'Authorization': getApiAuthHeader(),
          },
          body: JSON.stringify({
            code: code,
            currency: currency,
            subtotal: currency === 'IDR' ? itemSubtotalIdr : itemSubtotalUsd,
          }),
        });

        var data = await res.json();

        if (!data.valid) {
          appliedPromo = null;
          setPromoMessage(data.message || 'invalid promo code', true);
        } else {
          appliedPromo = data;
          setPromoMessage(data.description || 'promo code applied!', false);
        }
        updateTotals();
      } catch {
        appliedPromo = null;
        setPromoMessage('could not validate promo code. try again.', true);
        updateTotals();
      } finally {
        promoApplyBtn.disabled = false;
        promoApplyBtn.textContent = 'apply';
      }
    }

    promoApplyBtn.addEventListener('click', applyPromoCode);
    promoCodeInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        applyPromoCode();
      }
    });

    updateTotals();

    // Auto-select country based on currency
    if (currency === 'IDR') {
      document.getElementById('country').value = 'ID';
      updateTotals();
    }

    // Submit order
    document.getElementById('checkout-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      errorEl.classList.add('hidden');
      const btn = document.getElementById('submit-btn');
      btn.textContent = 'processing...';
      btn.disabled = true;

      const countryCode = document.getElementById('country').value;
      if (!countryCode) {
        errorEl.textContent = 'please select a shipping country.';
        errorEl.classList.remove('hidden');
        btn.textContent = 'proceed to payment';
        btn.disabled = false;
        return;
      }

      if (!SUPABASE_URL || !SUPABASE_KEY) {
        localStorage.removeItem('paperain-cart');
        updateCartCount();
        document.getElementById('checkout-form').classList.add('hidden');
        document.getElementById('order-success').classList.remove('hidden');
        return;
      }

      try {
        const orderRes = await fetch(`${SUPABASE_URL}/functions/v1/place-order`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'apikey': SUPABASE_KEY,
            'Authorization': getApiAuthHeader(),
          },
          body: JSON.stringify({
            items: cart.map(item => ({
              id: item.id,
              title: item.title,
              qty: item.qty,
              image: item.image,
            })),
            currency: currency,
            promo_code: appliedPromo ? appliedPromo.code : (promoCodeInput.value.trim() || null),
            shipping_name: document.getElementById('name').value,
            shipping_email: document.getElementById('email').value,
            shipping_phone: document.getElementById('phone').value,
            shipping_address: document.getElementById('address').value,
            shipping_country: countryCode,
            notes: document.getElementById('notes').value || null,
            customer_id: user ? user.id : null,
          }),
        });

        var result = {};
        try {
          result = await orderRes.json();
        } catch (parseErr) {
          throw new Error('invalid_response');
        }

        if (!orderRes.ok) {
          if (orderRes.status === 401 || orderRes.status === 403) {
            throw new Error('session');
          }
          if (result.error && result.error.includes('promo')) {
            throw new Error('promo_invalid');
          }
          if (result.error && result.error.includes('items failed')) {
            throw new Error('items_failed');
          }
          throw new Error(result.error || 'order_failed');
        }

        const order = result.order;
        if (!order || !order.id) {
          throw new Error('invalid_order_response');
        }

        localStorage.removeItem('paperain-cart');
        updateCartCount();

        window.location.href = '/payment?id=' + order.id;
      } catch (err) {
        var msg = 'something went wrong. please try again later.';
        if (err.message === 'session') {
          msg = 'your session has expired. please sign in again to place your order.';
        } else if (err.message === 'promo_invalid') {
          msg = 'your promo code is no longer valid. please remove it or try another code.';
          appliedPromo = null;
          updateTotals();
        } else if (err.message === 'order_failed' || err.message === 'invalid_order_response' || err.message === 'invalid_response') {
          msg = 'we couldn\'t process your order right now. please try again in a moment.';
        } else if (err.message === 'items_failed') {
          msg = 'your order was created but we had trouble saving the items. please contact us.';
        } else if (err.message && err.message.startsWith('product not found')) {
          msg = 'one or more items in your cart are no longer available. please refresh your cart and try again.';
        } else if (err.message === 'could not create order') {
          msg = 'we couldn\'t save your order. please try again in a moment.';
        } else if (err.message && err.message.length < 120) {
          msg = err.message;
        }
        errorEl.textContent = msg;
        errorEl.classList.remove('hidden');
        btn.textContent = 'proceed to payment';
        btn.disabled = false;
      }
    });
  })();
    });
  </script>
</Layout>
