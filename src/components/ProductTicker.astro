---
interface TickerItem {
  id: string;
  title: string;
  image: string;
  price: number;
}

interface Props {
  items: TickerItem[];
}

const { items } = Astro.props;
const doubled = [...items, ...items];
---

<div class="overflow-hidden bg-buttermilk py-6">
  <div class="ticker-track flex items-center gap-8">
    {doubled.map(item => (
      <a href={`/product/${item.id}`} class="ticker-item flex items-center gap-3 shrink-0 group">
        <div class="w-14 h-14 rounded-full overflow-hidden bg-white shadow-sm shrink-0">
          <img src={item.image} alt={item.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300" />
        </div>
        <span class="text-sm font-medium text-burgundy whitespace-nowrap group-hover:underline">{item.title}</span>
        <span class="text-burgundy/40 text-lg shrink-0">&bull;</span>
      </a>
    ))}
  </div>
</div>

<style>
  .ticker-track {
    animation: ticker-scroll 25s linear infinite;
    width: max-content;
  }

  .ticker-track:hover {
    animation-play-state: paused;
  }

  @keyframes ticker-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>
