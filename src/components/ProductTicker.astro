---
interface TickerItem {
  id: string;
  title: string;
  image: string;
  price: number;
}

interface Props {
  items: TickerItem[];
}

const { items } = Astro.props;
const doubled = [...items, ...items];
---

<div class="overflow-hidden bg-buttermilk py-8 sm:py-10">
  <div class="ticker-track flex items-center gap-6 sm:gap-10">
    {doubled.map(item => (
      <a href={`/product/${item.id}`} class="ticker-item shrink-0 group">
        <div class="w-[40vw] sm:w-[28vw] md:w-[22vw] lg:w-[18vw] aspect-square rounded-2xl overflow-hidden bg-white shadow-md">
          <img src={item.image} alt={item.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
        </div>
      </a>
    ))}
  </div>
</div>

<style>
  .ticker-track {
    animation: ticker-scroll 30s linear infinite;
    width: max-content;
  }

  .ticker-track:hover {
    animation-play-state: paused;
  }

  @keyframes ticker-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>
