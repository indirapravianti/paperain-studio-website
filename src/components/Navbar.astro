---
---

<nav class="sticky top-0 bg-white/95 backdrop-blur-sm z-30 border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 shrink-0 market-aware-link" data-href="/">
        <img src="/images/logo.jpg" alt="Paperain Studio" class="h-8 w-auto" />
        <span class="text-lg font-semibold tracking-tight hidden sm:block">paperain studio</span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-8">
        <a href="/products" class="text-sm text-gray-600 hover:text-primary transition-colors market-aware-link" data-href="/products">Products</a>
        <a href="/about" class="text-sm text-gray-600 hover:text-primary transition-colors market-aware-link" data-href="/about">About</a>

        <!-- Store Policy Dropdown -->
        <div class="relative group">
          <button class="text-sm text-gray-600 hover:text-primary transition-colors flex items-center gap-1">
            Store Policy
            <svg class="w-3.5 h-3.5 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            <div class="bg-white rounded-lg shadow-lg border border-gray-100 py-2 min-w-[200px]">
              <a href="/policies/shipping-refund" class="block px-4 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-primary market-aware-link" data-href="/policies/shipping-refund">Shipping & Refund</a>
              <a href="/policies/terms" class="block px-4 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-primary market-aware-link" data-href="/policies/terms">Terms & Conditions</a>
              <a href="/policies/privacy" class="block px-4 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-primary market-aware-link" data-href="/policies/privacy">Privacy Policy</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Right side -->
      <div class="flex items-center gap-3">
        <!-- Cart -->
        <button onclick="toggleCart(true)" class="relative p-2 text-gray-600 hover:text-primary transition-colors" aria-label="open cart">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
          </svg>
          <span class="cart-count absolute -top-0.5 -right-0.5 w-4 h-4 bg-burgundy text-white text-[10px] rounded-full items-center justify-center font-medium hidden">0</span>
        </button>

        <!-- Auth: Sign In (guest only — hidden by default until JS runs) -->
        <a href="/auth/signin" id="nav-signin" class="hidden items-center gap-1.5 text-sm border border-gray-200 rounded-full px-4 py-1.5 text-gray-600 hover:border-gray-300 hover:text-primary transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          sign in
        </a>
        <!-- Auth: Account name (signed in only) -->
        <a href="/account" id="nav-account" class="hidden items-center gap-1.5 text-sm border border-gray-200 rounded-full px-4 py-1.5 text-gray-600 hover:border-gray-300 hover:text-primary transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          <span id="nav-account-name">account</span>
        </a>

        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="md:hidden p-2 text-gray-600" onclick="document.getElementById('mobile-menu').classList.toggle('hidden')">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white">
    <div class="px-4 py-4 space-y-3">
      <a href="/products" class="block text-sm text-gray-600 hover:text-primary market-aware-link" data-href="/products">Products</a>
      <a href="/about" class="block text-sm text-gray-600 hover:text-primary market-aware-link" data-href="/about">About</a>
      <div class="border-t border-gray-50 pt-3">
        <p class="text-xs text-gray-400 uppercase tracking-wide mb-2">Store Policy</p>
        <a href="/policies/shipping-refund" class="block text-sm text-gray-600 hover:text-primary py-1 market-aware-link" data-href="/policies/shipping-refund">Shipping & Refund</a>
        <a href="/policies/terms" class="block text-sm text-gray-600 hover:text-primary py-1 market-aware-link" data-href="/policies/terms">Terms & Conditions</a>
        <a href="/policies/privacy" class="block text-sm text-gray-600 hover:text-primary py-1 market-aware-link" data-href="/policies/privacy">Privacy Policy</a>
      </div>
      <div class="border-t border-gray-50 pt-3" id="mobile-auth-guest">
        <a href="/auth/signin" id="mobile-signin" class="inline-flex items-center gap-1.5 text-sm text-gray-600 market-aware-link" data-href="/auth/signin">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          sign in
        </a>
        <a href="/auth/signup" class="inline-flex items-center gap-1.5 text-sm text-primary mt-2 market-aware-link" data-href="/auth/signup">create account</a>
      </div>
      <div class="border-t border-gray-50 pt-3 hidden" id="mobile-auth-user">
        <a href="/account" class="inline-flex items-center gap-1.5 text-sm text-gray-600 market-aware-link" data-href="/account">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          <span id="mobile-account-name">my account</span>
        </a>
      </div>
    </div>
  </div>
</nav>
