---
---

<footer class="bg-burgundy text-white/90 mt-0">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <img src="/images/logo.jpg" alt="paperain studio" class="h-8 w-auto rounded" />
          <span class="font-semibold text-white">paperain studio</span>
        </div>
        <p class="text-sm text-white/60 leading-relaxed">cute stickers, keychains, griptoks, and more — designed with love.</p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-medium mb-3 text-buttermilk">quick links</h3>
        <ul class="space-y-2">
          <li><a href="/products" class="text-sm text-white/60 hover:text-buttermilk transition-colors">products</a></li>
          <li><a href="/about" class="text-sm text-white/60 hover:text-buttermilk transition-colors">about</a></li>
          <li><a href="/blog" class="text-sm text-white/60 hover:text-buttermilk transition-colors">blog</a></li>
        </ul>
      </div>

      <!-- Policies -->
      <div>
        <h3 class="text-sm font-medium mb-3 text-buttermilk">store policy</h3>
        <ul class="space-y-2">
          <li><a href="/policies/shipping-refund" class="text-sm text-white/60 hover:text-buttermilk transition-colors">shipping & refund</a></li>
          <li><a href="/policies/terms" class="text-sm text-white/60 hover:text-buttermilk transition-colors">terms & conditions</a></li>
          <li><a href="/policies/privacy" class="text-sm text-white/60 hover:text-buttermilk transition-colors">privacy policy</a></li>
        </ul>
      </div>

      <!-- Social & Stores -->
      <div>
        <h3 class="text-sm font-medium mb-3 text-buttermilk">find us</h3>
        <ul class="space-y-2">
          <li>
            <a href="https://instagram.com/paperainstudio" target="_blank" rel="noopener noreferrer" class="text-sm text-white/60 hover:text-buttermilk transition-colors inline-flex items-center gap-2">
