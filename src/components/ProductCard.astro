---
import { getIdrPriceForCategory } from '../lib/idr-prices.js';

interface Props {
  id: string;
  title: string;
  price: number;
  image: string;
  isNew?: boolean;
  category?: string;
  priceIdr?: number;
}

const { id, title, price, image, isNew, category, priceIdr } = Astro.props;
const displayIdr = priceIdr ?? getIdrPriceForCategory(category);
---

<a href={`/product/${id}`} class="group block market-aware-link" data-href={`/product/${id}`}>
  <div class="relative aspect-square overflow-hidden rounded-xl bg-gray-50">
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
    />
    {isNew && (
      <span class="absolute top-3 left-3 bg-accent text-white text-[10px] uppercase tracking-wider font-medium px-2.5 py-1 rounded-full">
        New
      </span>
    )}
    <span class="stock-badge hidden absolute top-3 right-3 text-[10px] uppercase tracking-wider font-medium px-2.5 py-1 rounded-full" data-product-id={id}></span>
  </div>
  <div class="mt-3 px-0.5">
    <h3 class="text-sm font-medium text-gray-800 group-hover:text-primary transition-colors line-clamp-2">{title}</h3>
    <p class="market-price text-sm text-gray-500 mt-1" data-usd={price} data-idr={displayIdr}>${price.toFixed(2)}</p>
  </div>
</a>

<script is:inline define:vars={{ productId: id }}>
  (function() {
    document.addEventListener('DOMContentLoaded', function() {
      fetch('/api/stock?ids=' + encodeURIComponent(productId))
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var info = data.stock && data.stock[productId];
          if (!info) return;
          var badge = document.querySelector('.stock-badge[data-product-id="' + productId + '"]');
          if (!badge) return;
          if (info.status === 'restocking') {
            badge.textContent = 'restocking';
            badge.className = 'stock-badge absolute top-3 right-3 text-[10px] uppercase tracking-wider font-medium px-2.5 py-1 rounded-full bg-amber-100 text-amber-700';
          } else if (!info.purchasable) {
            badge.textContent = 'sold out';
            badge.className = 'stock-badge absolute top-3 right-3 text-[10px] uppercase tracking-wider font-medium px-2.5 py-1 rounded-full bg-gray-200 text-gray-600';
          } else if (info.available != null && info.available <= 3) {
            badge.textContent = info.available + ' left';
            badge.className = 'stock-badge absolute top-3 right-3 text-[10px] uppercase tracking-wider font-medium px-2.5 py-1 rounded-full bg-orange-100 text-orange-700';
          }
        })
        .catch(function() {});
    });
  })();
</script>
